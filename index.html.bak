<!DOCTYPE html>
<html lang="ru">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>CortexMD v4</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700&family=DM+Sans:wght@400;500;600&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">
<style>
:root{
  --bg-deep:#080b12;--bg-base:#0d1117;--bg-elevated:#141820;--bg-surface:#1a1f2e;
  --glass:rgba(255,255,255,0.03);--glass-hover:rgba(255,255,255,0.06);
  --glass-border:rgba(255,255,255,0.08);--glass-border-hover:rgba(255,255,255,0.15);
  --text-primary:#f0f2f5;--text-secondary:#9ba3b5;--text-muted:#5a6478;
  --accent:#6ee7b7;--accent-dim:rgba(110,231,183,0.15);--accent-glow:rgba(110,231,183,0.08);
  --accent-blue:#818cf8;--accent-blue-dim:rgba(129,140,248,0.15);
  --status-optimal:#22c55e;--status-warning:#f59e0b;--status-danger:#ef4444;
  --shadow-sm:0 2px 8px rgba(0,0,0,0.3);--shadow-md:0 8px 32px rgba(0,0,0,0.4);
  --radius-sm:8px;--radius-md:12px;--radius-lg:16px;
  --ease:cubic-bezier(0.4,0,0.2,1);--dur:0.25s;
  --font-head:'Outfit',sans-serif;--font-body:'DM Sans',sans-serif;--font-mono:'JetBrains Mono',monospace;
}
*{margin:0;padding:0;box-sizing:border-box}
body{background:var(--bg-deep);color:var(--text-primary);font-family:var(--font-body);overflow:hidden;height:100vh}

/* === 3D CANVAS + AMBIENT GLOW === */
#cv{position:absolute;inset:0;z-index:0;
  background:linear-gradient(rgba(255,255,255,0.015) 1px,transparent 1px),linear-gradient(90deg,rgba(255,255,255,0.015) 1px,transparent 1px),radial-gradient(ellipse at 50% 45%,rgba(110,231,183,0.12) 0%,rgba(129,140,248,0.08) 35%,transparent 65%),#080b12;
  background-size:50px 50px,50px 50px,100% 100%,100% 100%}
.cv-btn{position:absolute;top:12px;left:50%;transform:translateX(-50%);z-index:10;
  padding:5px 14px;font-size:9px;font-family:var(--font-mono);font-weight:600;
  background:rgba(15,23,42,0.7);backdrop-filter:blur(8px);color:var(--text-secondary);
  border:1px solid rgba(255,255,255,0.08);border-radius:var(--radius-full);cursor:pointer;
  transition:all var(--dur) var(--ease);letter-spacing:0.3px}
.cv-btn:hover{background:rgba(30,41,59,0.8);color:var(--text-primary);border-color:rgba(255,255,255,0.15)}
.cv-btn.active{background:rgba(99,102,241,0.2);color:#a78bfa;border-color:rgba(167,139,250,0.3)}
#cv canvas{position:relative;z-index:3;background:transparent !important}
#cv::before{content:'';position:absolute;left:0;top:10%;bottom:10%;width:40px;z-index:2;pointer-events:none;
  background:repeating-linear-gradient(to bottom,transparent,transparent 8px,rgba(110,231,183,0.06) 8px,rgba(110,231,183,0.06) 9px);
  mask-image:linear-gradient(to bottom,transparent,white 20%,white 80%,transparent);
  -webkit-mask-image:linear-gradient(to bottom,transparent,white 20%,white 80%,transparent)}
#cv::after{content:'';position:absolute;right:0;top:10%;bottom:10%;width:40px;z-index:2;pointer-events:none;
  background:repeating-linear-gradient(to bottom,transparent,transparent 8px,rgba(129,140,248,0.06) 8px,rgba(129,140,248,0.06) 9px);
  mask-image:linear-gradient(to bottom,transparent,white 20%,white 80%,transparent);
  -webkit-mask-image:linear-gradient(to bottom,transparent,white 20%,white 80%,transparent)}

@keyframes blobD{0%{transform:translate(0,0) scale(1)}33%{transform:translate(30px,-20px) scale(1.1)}66%{transform:translate(-20px,30px) scale(0.9)}100%{transform:translate(10px,-10px) scale(1.05)}}

/* === SCROLLBAR === */
::-webkit-scrollbar{width:5px}
::-webkit-scrollbar-track{background:transparent}
::-webkit-scrollbar-thumb{background:rgba(255,255,255,0.1);border-radius:3px}
::-webkit-scrollbar-thumb:hover{background:rgba(255,255,255,0.18)}

/* === LEFT PANEL === */
#lp{position:absolute;left:0;top:0;bottom:48px;width:280px;z-index:10;
  background:rgba(13,17,23,0.85);border-right:1px solid rgba(255,255,255,0.08);
  overflow-y:auto;padding:14px;backdrop-filter:blur(30px);-webkit-backdrop-filter:blur(30px)}

/* === RIGHT PANEL — hidden by default, slides in === */
#rp{position:fixed;right:0;top:0;bottom:48px;width:340px;z-index:15;
  background:rgba(13,17,23,0.92);border-left:1px solid var(--glass-border);
  overflow-y:auto;padding:16px;backdrop-filter:blur(30px) saturate(1.2);-webkit-backdrop-filter:blur(30px) saturate(1.2);
  transform:translateX(100%);transition:transform 0.3s var(--ease)}
#rp.open{transform:translateX(0)}

/* Panel toggle tab */
#panel-toggle{position:fixed;right:0;top:50%;transform:translateY(-50%);z-index:16;
  width:28px;height:80px;background:rgba(13,17,23,0.8);backdrop-filter:blur(10px);
  border:1px solid var(--glass-border);border-right:none;border-radius:8px 0 0 8px;
  color:var(--text-muted);font-size:10px;cursor:pointer;display:flex;align-items:center;
  justify-content:center;writing-mode:vertical-rl;text-orientation:mixed;
  transition:all 0.3s var(--ease);font-family:var(--font-body);letter-spacing:0.3px}
#panel-toggle:hover{background:rgba(13,17,23,0.95);color:var(--text-primary);width:32px}
#rp.open~#panel-toggle{right:340px}
#panel-toggle .badge{position:absolute;top:8px;left:50%;transform:translateX(-50%);
  width:8px;height:8px;border-radius:50%;background:#ef4444;
  animation:pulse-badge 2s infinite}
@keyframes pulse-badge{0%,100%{opacity:1;box-shadow:0 0 4px #ef4444}50%{opacity:0.5;box-shadow:0 0 8px #ef4444}}
#panel-toggle .badge.hidden{display:none}

/* Panel close button */
.panel-close{position:sticky;top:0;float:right;background:none;border:none;color:var(--text-muted);
  font-size:20px;cursor:pointer;width:28px;height:28px;display:flex;align-items:center;
  justify-content:center;border-radius:6px;z-index:1}
.panel-close:hover{background:var(--glass);color:var(--text-primary)}

/* === LOGO === */
.logo{font-family:var(--font-head);font-size:22px;font-weight:700;text-align:center;padding:8px 0 2px;letter-spacing:-0.5px;
  background:linear-gradient(135deg,var(--accent),var(--accent-blue));-webkit-background-clip:text;-webkit-text-fill-color:transparent}
.sub{font-family:var(--font-body);font-size:9px;text-align:center;color:var(--text-muted);margin-bottom:12px;letter-spacing:0.5px;text-transform:uppercase}

/* === SECTIONS (collapsible) === */
.section{border:1px solid var(--glass-border);border-radius:var(--radius-md);margin-bottom:8px;overflow:hidden;
  background:var(--glass);transition:border-color var(--dur) var(--ease)}
.section:hover{border-color:var(--glass-border-hover)}
.sh{display:flex;justify-content:space-between;align-items:center;padding:9px 12px;
  background:rgba(255,255,255,0.02);cursor:pointer;user-select:none;transition:background var(--dur) var(--ease)}
.sh:hover{background:rgba(255,255,255,0.04)}
.st{font-family:var(--font-head);font-size:11px;font-weight:600;color:var(--text-secondary);text-transform:uppercase;letter-spacing:0.6px}
.sa{font-size:10px;color:var(--text-muted);transition:transform .2s var(--ease)}
.sa.open{transform:rotate(180deg)}
.sb{padding:8px;display:none}
.sb.open{display:block}

/* === DRUG GRID === */
.dg{display:flex;flex-wrap:wrap;gap:4px}
.di{display:flex;align-items:center;gap:6px;padding:5px 8px;border-radius:var(--radius-sm);cursor:pointer;
  border:1px solid transparent;font-size:10px;color:var(--text-muted);transition:all var(--dur) var(--ease);min-width:calc(50% - 4px)}
.di:hover{background:var(--glass-hover);color:var(--text-secondary)}
.di.on{border-color:var(--c);background:color-mix(in srgb,var(--c) 8%,transparent);color:var(--c);font-weight:600}
.ddt{width:8px;height:8px;border-radius:50%;border:2px solid var(--c);flex-shrink:0;transition:all var(--dur) var(--ease)}
.di.on .ddt{background:var(--c);box-shadow:0 0 8px var(--c)}

/* === DOSE SLIDER === */
.dr{display:none;padding:6px 8px;background:var(--bg-elevated);border-radius:var(--radius-sm);margin:3px 0;
  border:1px solid var(--glass-border)}
.dr.show{display:block}
.dr input[type=range]{width:100%;height:16px;accent-color:var(--c);cursor:pointer}
.dinfo{display:flex;justify-content:space-between;font-family:var(--font-mono);font-size:8px;color:var(--text-muted)}
.dwarn{font-size:8px;color:#f59e0b;margin-top:2px;display:none;font-family:var(--font-mono)}
.dwarn.show{display:block}
.dwarn.danger{color:#ef4444}
.dval{font-family:var(--font-mono);font-size:11px;font-weight:500;text-align:center;letter-spacing:-0.3px}

/* === ACTIVE SCHEME === */
#active-scheme{padding:8px 0;min-height:32px}
.empty-scheme{text-align:center;padding:16px 10px;color:var(--text-muted);font-size:11px;font-style:italic}
.scheme-grid{display:grid;grid-template-columns:1fr 1fr;gap:6px}
.scheme-card{background:rgba(255,255,255,0.03);border:1px solid rgba(255,255,255,0.08);border-left:3px solid var(--c);
  border-radius:8px;padding:7px 8px;position:relative;transition:all var(--dur) var(--ease);
  backdrop-filter:blur(10px);-webkit-backdrop-filter:blur(10px)}
.scheme-card:hover{border-color:var(--glass-border-hover);background:var(--glass-hover)}
.scheme-header{display:flex;align-items:center;gap:4px;margin-bottom:1px}
.scheme-dot{width:6px;height:6px;border-radius:50%;flex-shrink:0}
.scheme-name{font-size:10px;font-weight:600;color:var(--c);flex:1;font-family:var(--font-head)}
.scheme-remove{background:none;border:none;color:var(--text-muted);font-size:14px;cursor:pointer;padding:0 2px;line-height:1;transition:color var(--dur)}
.scheme-remove:hover{color:#ef4444}
.scheme-dose{font-family:var(--font-mono);font-size:12px;font-weight:500;color:var(--text-primary);margin:1px 0}
.scheme-real-dose{font-size:8px;color:var(--accent);font-family:var(--font-mono)}
.scheme-warning{position:absolute;top:4px;right:20px;font-size:11px}
.scheme-warn-text{font-size:7px;color:#f59e0b;font-family:var(--font-mono);margin-top:1px}
.scheme-slider{width:100%;margin-top:3px}
.catalog-toggle-btn{width:100%;display:flex;justify-content:space-between;align-items:center;padding:9px 12px;
  background:rgba(255,255,255,0.02);border:none;border-top:1px solid var(--glass-border);
  color:var(--text-secondary);font-size:11px;font-weight:600;cursor:pointer;
  font-family:var(--font-head);text-transform:uppercase;letter-spacing:0.5px;transition:all var(--dur) var(--ease)}
.catalog-toggle-btn:hover{color:var(--text-primary);background:rgba(255,255,255,0.04)}
#catalog-section{display:none;padding:8px}
#catalog-section.open{display:block}
.di.in-scheme{opacity:0.4;position:relative}
.di.in-scheme::after{content:'\2713';position:absolute;right:4px;top:50%;transform:translateY(-50%);font-size:9px;color:var(--accent)}

/* === PRESETS === */
.pl{display:flex;flex-wrap:wrap;gap:4px}
.pb{padding:6px 10px;font-size:10px;border-radius:var(--radius-sm);
  border:1px solid var(--glass-border);background:var(--glass);color:var(--text-secondary);
  cursor:pointer;flex:1;min-width:45%;text-align:center;font-family:var(--font-body);
  transition:all var(--dur) var(--ease)}
.pb:hover{border-color:var(--glass-border-hover);color:var(--text-primary);background:var(--glass-hover);box-shadow:var(--shadow-sm)}

/* === CARDS (right panel) === */
.card{background:var(--glass);backdrop-filter:blur(10px);-webkit-backdrop-filter:blur(10px);
  border:1px solid var(--glass-border);border-radius:var(--radius-md);padding:14px;margin-bottom:8px;
  transition:border-color var(--dur) var(--ease),box-shadow var(--dur) var(--ease)}
.card:hover{border-color:var(--glass-border-hover);box-shadow:var(--shadow-sm)}
.ct{font-family:var(--font-head);font-size:15px;font-weight:600;color:var(--text-primary);margin-bottom:4px}
.cs{font-size:10px;color:var(--text-secondary);line-height:1.5;margin-bottom:8px}

/* === RECEPTOR BADGES === */
.rg{display:flex;flex-wrap:wrap;gap:3px;margin-bottom:8px}
.rc{font-family:var(--font-mono);font-size:8px;padding:3px 6px;border-radius:5px;border:1px solid rgba(255,255,255,0.1);color:var(--text-secondary);
  transition:all var(--dur) var(--ease)}
.rc.h{border-color:rgba(34,197,94,0.4);color:#86efac;background:rgba(34,197,94,0.1)}
.rc.m{border-color:rgba(245,158,11,0.4);color:#fde68a;background:rgba(245,158,11,0.08)}
.rc.l{border-color:rgba(255,255,255,0.08);color:var(--text-muted)}
.rc.a{border-color:rgba(239,68,68,0.4);color:#fca5a5;background:rgba(239,68,68,0.08);text-decoration:line-through}

/* === DRUG EFFECT ITEMS === */
.fi{padding:6px 8px;margin-bottom:4px;border-radius:var(--radius-sm);border-left:3px solid var(--c);
  background:rgba(255,255,255,0.02);transition:background var(--dur) var(--ease)}
.fi:hover{background:rgba(255,255,255,0.04)}
.fi.bad{border-left-color:var(--status-danger);background:rgba(239,68,68,0.06)}
.fd{font-size:10px;font-weight:600}
.fx{font-size:9px;color:var(--text-secondary);margin-top:2px;line-height:1.4}
.fo{font-family:var(--font-mono);font-size:8px;color:var(--text-muted);margin-top:3px;display:flex;flex-wrap:wrap;gap:3px}
.fo-bar{display:inline-flex;align-items:center;gap:3px}
.fo-bar-track{width:32px;height:3px;background:rgba(255,255,255,0.06);border-radius:2px;overflow:hidden}
.fo-bar-fill{height:100%;border-radius:2px;transition:width .3s ease}
.fo-bar-lbl{font-size:7px;color:var(--text-muted);font-family:var(--font-mono)}
.nb{display:inline-block;font-size:8px;padding:2px 5px;border-radius:4px;margin-right:2px;font-weight:500}

/* === CONFLICT BOX === */
.cb{background:rgba(239,68,68,0.06);border:1px solid rgba(239,68,68,0.2);border-radius:var(--radius-md);padding:10px;margin-bottom:8px}
.cbt{font-family:var(--font-head);font-size:11px;font-weight:600;color:var(--status-warning);margin-bottom:4px;text-transform:uppercase;letter-spacing:0.3px}
.ci{font-size:10px;color:#fde68a;margin-bottom:2px;line-height:1.4}

/* === BOTTOM BAR === */
#bb{position:absolute;bottom:0;left:0;right:0;height:48px;z-index:10;
  background:rgba(8,11,18,0.95);border-top:1px solid rgba(255,255,255,0.08);
  display:flex;align-items:center;padding:0 16px;gap:0;
  backdrop-filter:blur(30px);-webkit-backdrop-filter:blur(30px)}
.hb{flex:1;padding:4px 8px;text-align:center;position:relative;border-right:1px solid rgba(255,255,255,0.06)}
.hb:last-child{border-right:none}
.hl{font-family:var(--font-body);font-size:9px;color:rgba(155,163,181,0.7);margin-bottom:2px;text-transform:uppercase;letter-spacing:1px}
.hv{font-family:var(--font-mono);font-size:18px;font-weight:500;letter-spacing:-0.5px}
.hbar{height:2px;background:rgba(255,255,255,0.06);border-radius:1px;overflow:hidden;margin-top:3px}
.hfill{height:100%;border-radius:1px;transition:width 0.5s var(--ease),background 0.5s var(--ease)}
.hs{display:none}

/* === TOOLTIP === */
#tooltip{position:absolute;z-index:20;padding:8px 12px;
  background:rgba(13,17,23,0.9);backdrop-filter:blur(16px);-webkit-backdrop-filter:blur(16px);
  border:1px solid var(--glass-border-hover);border-radius:var(--radius-sm);
  font-size:11px;color:var(--text-primary);pointer-events:none;display:none;max-width:240px;
  box-shadow:var(--shadow-md)}

/* === SEARCH === */
.dsearch{width:100%;padding:8px 10px;background:var(--bg-surface);
  border:1px solid var(--glass-border);border-radius:var(--radius-sm);
  color:var(--text-primary);font-family:var(--font-body);font-size:12px;margin-bottom:8px;outline:none;
  transition:border-color var(--dur) var(--ease),box-shadow var(--dur) var(--ease)}
.dsearch:focus{border-color:var(--accent);box-shadow:0 0 0 3px var(--accent-dim)}
.dsearch::placeholder{color:var(--text-muted)}

/* === CATEGORY TABS === */
.dtabs{display:flex;flex-wrap:wrap;gap:3px;margin-bottom:8px}
.dtab{padding:4px 8px;font-family:var(--font-body);font-size:9px;border-radius:6px;
  border:1px solid transparent;background:transparent;color:var(--text-muted);
  cursor:pointer;text-transform:uppercase;letter-spacing:0.4px;font-weight:500;
  transition:all var(--dur) var(--ease)}
.dtab:hover{color:var(--text-secondary);background:var(--glass)}
.dtab.act{color:var(--text-primary);background:var(--glass);border-color:var(--glass-border-hover)}

/* === MISC === */
.disclaimer{font-size:8px;color:var(--text-muted);text-align:center;padding:6px;border-top:1px solid var(--glass-border);margin-top:6px}

/* === ZONE POPUP on canvas === */
.zone-popup{position:fixed;z-index:20;width:260px;background:rgba(13,17,23,0.95);
  backdrop-filter:blur(30px);border:1px solid var(--glass-border);border-radius:12px;
  padding:14px;box-shadow:0 16px 48px rgba(0,0,0,0.5);pointer-events:auto;
  transition:opacity 0.2s ease,transform 0.2s ease}
.zone-popup.hidden{opacity:0;transform:scale(0.95);pointer-events:none}
.zone-popup-header{display:flex;align-items:flex-start;gap:10px;margin-bottom:10px}
.zone-popup-dot{width:10px;height:10px;border-radius:50%;flex-shrink:0;margin-top:4px}
.zone-popup-title{font-family:var(--font-head);font-size:15px;font-weight:600;color:var(--text-primary);line-height:1.2}
.zone-popup-subtitle{font-size:11px;color:var(--text-secondary);margin-top:2px}
.zone-popup-close{background:none;border:none;color:var(--text-muted);font-size:16px;cursor:pointer;margin-left:auto;padding:0 4px}
.zone-popup-close:hover{color:var(--text-primary)}
.zone-popup-body{font-size:11px;color:var(--text-secondary);line-height:1.5}
.popup-effect{display:flex;align-items:center;gap:6px;margin:3px 0;font-size:11px}
.popup-effect-arrow{font-size:13px;flex-shrink:0}
.popup-effect-arrow.up{color:#22c55e}.popup-effect-arrow.down{color:#ef4444}
.popup-effect-name{color:var(--text-primary);font-weight:600;font-size:10px}
.popup-effect-detail{color:var(--text-muted);font-size:10px}
.zone-popup-more{display:block;width:100%;margin-top:10px;padding:6px;background:var(--glass);
  border:1px solid var(--glass-border);border-radius:6px;color:var(--accent);font-size:11px;
  cursor:pointer;text-align:center;font-family:var(--font-body);transition:all var(--dur) var(--ease)}
.zone-popup-more:hover{background:var(--glass-hover)}

/* === SIMPLIFIED RIGHT PANEL CONTENT === */
.zone-header-card{border-radius:10px;padding:14px 16px;margin-bottom:16px}
.zone-header-title{font-family:var(--font-head);font-size:18px;font-weight:600;color:var(--text-primary);margin-bottom:2px}
.zone-header-subtitle{font-size:13px;color:var(--text-secondary)}
.panel-section-title{font-size:10px;font-weight:700;color:var(--text-muted);text-transform:uppercase;letter-spacing:0.4px;margin:12px 0 6px;font-family:var(--font-head)}
.panel-effect{display:flex;align-items:center;gap:10px;padding:8px 0;border-bottom:1px solid rgba(255,255,255,0.04);font-size:14px}
.panel-effect:last-child{border-bottom:none}
.panel-effect-icon{width:24px;height:24px;border-radius:6px;display:flex;align-items:center;justify-content:center;font-size:14px;flex-shrink:0}
.panel-effect-icon.up{background:rgba(34,197,94,0.15);color:#22c55e}
.panel-effect-icon.down{background:rgba(239,68,68,0.15);color:#ef4444}
.panel-effect-icon.neutral{background:rgba(100,116,139,0.15);color:#64748b}
.panel-effect-drug{font-weight:600;color:var(--text-primary);min-width:45px;font-size:13px}
.panel-effect-desc{color:var(--text-secondary);font-size:12px}
.cvbtn{display:inline-flex;align-items:center;gap:4px;padding:6px 12px;font-size:10px;font-weight:500;
  border-radius:var(--radius-sm);border:1px solid rgba(168,85,247,0.3);color:#c084fc;
  background:rgba(168,85,247,0.08);cursor:pointer;margin-top:6px;transition:all var(--dur) var(--ease)}
.cvbtn:hover{background:rgba(168,85,247,0.18);border-color:rgba(168,85,247,0.5);box-shadow:0 0 20px rgba(168,85,247,0.1)}

/* === σ1 OVERLAY === */
#s1overlay{position:fixed;inset:0;z-index:100;
  background:rgba(8,11,18,0.92);display:none;flex-direction:column;align-items:center;justify-content:center;
  backdrop-filter:blur(32px) saturate(1.1);-webkit-backdrop-filter:blur(32px) saturate(1.1)}
#s1overlay.show{display:flex}
.s1close{position:absolute;top:20px;right:28px;font-size:28px;color:var(--text-muted);cursor:pointer;z-index:101;
  transition:color var(--dur) var(--ease),transform var(--dur) var(--ease)}
.s1close:hover{color:var(--text-primary);transform:scale(1.1)}
.s1title{font-family:var(--font-head);font-size:20px;font-weight:600;margin-bottom:4px;text-align:center;
  background:linear-gradient(135deg,var(--accent),var(--accent-blue));-webkit-background-clip:text;-webkit-text-fill-color:transparent}
.s1sub{font-family:var(--font-body);font-size:11px;color:var(--text-secondary);margin-bottom:16px;text-align:center}
.s1legend{display:flex;gap:16px;justify-content:center;margin-top:12px;font-size:9px;color:var(--text-secondary)}
.s1legend span{display:flex;align-items:center;gap:4px}
.s1dot{width:8px;height:8px;border-radius:50%;display:inline-block}
.s1info{position:absolute;bottom:20px;left:50%;transform:translateX(-50%);max-width:560px;text-align:center;
  font-size:10px;color:#fde68a;line-height:1.5;
  background:rgba(251,191,36,0.06);border:1px solid rgba(251,191,36,0.2);border-radius:var(--radius-md);
  padding:10px 18px;display:none;backdrop-filter:blur(8px);-webkit-backdrop-filter:blur(8px)}
.s1info.show{display:block}
@keyframes s1flow{0%{offset-distance:0%}100%{offset-distance:100%}}
@keyframes s1pulse{0%,100%{opacity:.3}50%{opacity:1}}
.s1node{cursor:pointer;transition:filter var(--dur) var(--ease)}
.s1node:hover{filter:brightness(1.5)}
.s1tooltip{position:absolute;z-index:102;padding:8px 12px;
  background:rgba(13,17,23,0.92);backdrop-filter:blur(16px);-webkit-backdrop-filter:blur(16px);
  border:1px solid rgba(168,85,247,0.3);border-radius:var(--radius-sm);
  font-size:10px;color:var(--text-primary);pointer-events:none;display:none;max-width:260px;box-shadow:var(--shadow-md)}

/* === RANGE SLIDER CUSTOM === */
input[type=range]{-webkit-appearance:none;appearance:none;background:transparent;cursor:pointer}
input[type=range]::-webkit-slider-runnable-track{height:4px;background:rgba(255,255,255,0.08);border-radius:2px}
input[type=range]::-webkit-slider-thumb{-webkit-appearance:none;width:14px;height:14px;border-radius:50%;
  background:var(--text-primary);border:2px solid var(--bg-base);margin-top:-5px;
  box-shadow:0 0 6px rgba(0,0,0,0.4);transition:transform 0.15s var(--ease)}
input[type=range]::-webkit-slider-thumb:hover{transform:scale(1.2)}
input[type=range]::-moz-range-track{height:4px;background:rgba(255,255,255,0.08);border-radius:2px;border:none}
input[type=range]::-moz-range-thumb{width:12px;height:12px;border-radius:50%;background:var(--text-primary);border:2px solid var(--bg-base);
  box-shadow:0 0 6px rgba(0,0,0,0.4)}

/* Deficit card — collapsed */
.dc{background:var(--glass);border:1px solid var(--glass-border);border-radius:10px;
  padding:10px;margin-bottom:8px;cursor:pointer;transition:all var(--dur) var(--ease);position:relative}
.dc:hover{border-color:var(--glass-border-hover);background:var(--glass-hover)}
.dc.critical{border-left:3px solid var(--status-danger)}
.dc.working{border-left:3px solid var(--status-warning)}
.dc.compensated{border-left:3px solid var(--status-optimal)}
.dc.sel{background:rgba(255,255,255,0.06);border-color:var(--glass-border-hover)}

/* Deficit card header */
.dc-head{display:flex;align-items:center;gap:6px}
.dc-icon{font-size:14px;flex-shrink:0}
.dc-name{font-family:var(--font-head);font-size:11px;font-weight:600;color:var(--text-primary);flex:1;line-height:1.3}
.dc-status{width:8px;height:8px;border-radius:50%;flex-shrink:0}
.dc-status.critical{background:var(--status-danger);box-shadow:0 0 8px rgba(239,68,68,0.5);animation:dc-pulse 2s infinite}
.dc-status.working{background:var(--status-warning);box-shadow:0 0 6px rgba(245,158,11,0.4)}
.dc-status.compensated{background:var(--status-optimal);box-shadow:0 0 6px rgba(34,197,94,0.4)}
@keyframes dc-pulse{0%,100%{opacity:1}50%{opacity:0.4}}

/* Zone chips row */
.dc-zones{display:flex;flex-wrap:wrap;gap:3px;margin-top:6px}
.zc{font-family:var(--font-mono);font-size:8px;padding:2px 6px;border-radius:4px;
  background:rgba(255,255,255,0.05);border:1px solid var(--glass-border);color:var(--text-muted);
  cursor:pointer;transition:all var(--dur) var(--ease);white-space:nowrap}
.zc:hover{background:var(--accent-dim);color:var(--accent);border-color:rgba(110,231,183,0.3)}

/* Coverage mini-bar */
.dc-cov{margin-top:6px;display:flex;align-items:center;gap:6px}
.dc-cbar{flex:1;height:4px;border-radius:2px;background:rgba(255,255,255,0.06);overflow:hidden}
.dc-cfill{height:100%;border-radius:2px;transition:width 0.5s var(--ease)}
.dc-cpct{font-family:var(--font-mono);font-size:9px;color:var(--text-muted);min-width:24px;text-align:right}
.dc-block{font-size:8px;color:#f59e0b;padding:2px 6px;margin-top:3px;border-radius:4px;background:rgba(245,158,11,0.08);font-family:var(--font-mono)}
.dc-cnts{font-size:8px;color:var(--text-muted);margin-left:2px}

/* Deficit card — expanded */
.dc-body{display:none;margin-top:10px;border-top:1px solid var(--glass-border);padding-top:10px}
.dc.exp .dc-body{display:block}
.dc-desc{font-size:10px;color:var(--text-secondary);line-height:1.5;margin-bottom:10px}

/* Deficit sections inside expanded card */
.dc-sec{font-family:var(--font-head);font-size:9px;font-weight:600;color:var(--text-muted);
  text-transform:uppercase;letter-spacing:0.4px;margin:8px 0 4px}
.dc-def{padding:6px;margin-bottom:4px;border-radius:6px;background:rgba(255,255,255,0.02);border-left:2px solid var(--status-danger)}
.dc-def-title{font-family:var(--font-mono);font-size:9px;font-weight:500;color:var(--text-primary)}
.dc-def-mech{font-size:9px;color:var(--text-secondary);line-height:1.4;margin-top:2px}
.dc-def-src{font-size:8px;color:var(--text-muted);font-style:italic;margin-top:2px}

/* Coverage rows in expanded */
.dc-need{margin-bottom:6px}
.dc-need-title{font-size:9px;font-weight:500;color:var(--text-primary);margin-bottom:2px}
.dc-need-bar{display:flex;align-items:center;gap:6px}
.dc-need-fill{flex:1;height:4px;border-radius:2px;background:rgba(255,255,255,0.06);overflow:hidden}
.dc-need-fill>div{height:100%;border-radius:2px;transition:width 0.5s var(--ease)}
.dc-need-pct{font-family:var(--font-mono);font-size:9px;color:var(--text-muted);min-width:28px;text-align:right}
.dc-need-drugs{font-size:8px;color:var(--text-muted);margin-top:1px}
.dc-need-block{font-size:8px;color:var(--status-danger);margin-top:1px}
.dc-need-np{font-size:9px;color:var(--accent-blue);font-style:italic;padding:4px 6px;
  background:var(--accent-blue-dim);border-radius:6px}

/* AI placeholder */
.dc-ai{margin-top:10px;padding:8px;border-radius:8px;background:rgba(255,255,255,0.02);
  border:1px dashed var(--glass-border);text-align:center}
.dc-ai-text{font-size:9px;color:var(--text-muted)}

/* Footer actions */
.dc-foot{display:flex;justify-content:space-between;align-items:center;margin-top:10px;padding-top:8px;border-top:1px solid var(--glass-border)}
.dc-stsel{background:var(--bg-surface);border:1px solid var(--glass-border);border-radius:6px;
  color:var(--text-primary);font-size:10px;padding:3px 8px;font-family:var(--font-body);cursor:pointer}
.dc-del{font-size:9px;color:var(--status-danger);cursor:pointer;opacity:0.6;transition:opacity var(--dur) var(--ease)}
.dc-del:hover{opacity:1}
</style>
</head>
<body>
<div id="cv">
<div style="position:absolute;inset:0;z-index:0;pointer-events:none;overflow:hidden">
  <div style="position:absolute;width:400px;height:400px;border-radius:50%;filter:blur(100px);opacity:0.07;background:radial-gradient(circle,#6ee7b7,transparent 70%);top:20%;left:40%;animation:blobD 20s ease-in-out infinite alternate"></div>
  <div style="position:absolute;width:350px;height:350px;border-radius:50%;filter:blur(100px);opacity:0.07;background:radial-gradient(circle,#818cf8,transparent 70%);top:50%;left:60%;animation:blobD 25s ease-in-out infinite alternate;animation-delay:-7s"></div>
  <div style="position:absolute;width:300px;height:300px;border-radius:50%;filter:blur(100px);opacity:0.07;background:radial-gradient(circle,#f472b6,transparent 70%);bottom:20%;left:30%;animation:blobD 30s ease-in-out infinite alternate;animation-delay:-13s"></div>
</div>
</div>
<button id="defToggle" class="cv-btn" onclick="toggleDefView()">Дефициты</button>
<div id="tooltip"></div>
<div id="s1tooltip" class="s1tooltip"></div>
<div id="s1overlay">
  <span class="s1close" onclick="document.getElementById('s1overlay').classList.remove('show')">&times;</span>
  <div class="s1title">Клеточный уровень: σ1-каскад нейропластичности</div>
  <div class="s1sub" id="s1status">Нет активных σ1-лигандов</div>
  <svg id="s1svg" viewBox="0 0 800 520" style="width:min(90vw,900px);height:auto;max-height:70vh"></svg>
  <div class="s1legend">
    <span><span class="s1dot" style="background:#22c55e"></span> σ1-агонист (каскад активен)</span>
    <span><span class="s1dot" style="background:#ef4444"></span> σ1-инверсный агонист (подавлен)</span>
    <span><span class="s1dot" style="background:#f59e0b"></span> σ1-антагонист (блокирован)</span>
    <span><span class="s1dot" style="background:#475569"></span> Неактивен</span>
  </div>
  <div class="s1info" id="s1info"></div>
</div>

<div id="lp">
  <div class="logo">CortexMD</div>
  <div class="sub">Нейрофармакологическая карта v4</div>
  <div class="section"><div class="sh" onclick="tSec(this)"><span class="st">Пресеты</span><span class="sa">&#9660;</span></div><div class="sb"><div class="pl" id="presets"></div><button class="pb" style="margin-top:4px;width:100%;color:#34d399;border-color:#064e3b" onclick="saveP()">Сохранить текущую</button></div></div>
  <div class="section">
    <div class="sh"><span class="st">Активная схема</span><span style="font-size:9px;color:var(--text-muted);margin-left:auto" id="scheme-count"></span></div>
    <div class="sb open" style="display:block"><div id="active-scheme"></div></div>
    <button class="catalog-toggle-btn" onclick="toggleCatalog()">Каталог препаратов <span id="catalog-toggle">&#9660;</span></button>
    <div id="catalog-section"><input class="dsearch" id="dsearch" type="text" placeholder="Поиск препарата..." oninput="setDSQ(this.value)"><div class="dtabs" id="dtabs"></div><div id="dl"></div></div>
  </div>
  <div class="section"><div class="sh" onclick="tSec(this)"><span class="st">Мои дефициты</span><span class="sa">&#9660;</span></div><div class="sb"><div id="dfc"></div></div></div>
  <div class="section"><div class="sh" onclick="tSec(this)"><span class="st">Визуализация</span><span class="sa">&#9660;</span></div><div class="sb"><div style="font-size:9px;color:#94a3b8;margin-bottom:3px">Прозрачность коры</div><input type="range" style="width:100%;accent-color:#64748b" id="opsl" min="0" max="100" value="18"></div></div>
  <div style="margin-top:6px;font-size:7px;color:#1e293b;text-align:center">Meshy.ai CC BY 4.0</div>
</div>

<div id="zone-popup" class="zone-popup hidden">
  <div class="zone-popup-header">
    <div class="zone-popup-dot" id="zp-dot"></div>
    <div style="flex:1"><div class="zone-popup-title" id="zp-title"></div><div class="zone-popup-subtitle" id="zp-sub"></div></div>
    <button class="zone-popup-close" onclick="closeZonePopup()">&times;</button>
  </div>
  <div class="zone-popup-body" id="zp-body"></div>
  <button class="zone-popup-more" onclick="openRightPanelForZone()">Подробнее &rarr;</button>
</div>

<div id="rp">
  <button class="panel-close" onclick="toggleRightPanel()">&times;</button>
  <div id="cfb"></div>
  <div id="ri"></div>
</div>
<div id="panel-toggle" onclick="toggleRightPanel()"><span class="badge hidden" id="panel-badge"></span>Инфо</div>

<div id="bb">
  <div class="hb"><div class="hl">Дофамин (DA)</div><div class="hv" id="hv-da">-</div><div class="hbar"><div class="hfill" id="hf-da"></div></div><div class="hs" id="hs-da"></div></div>
  <div class="hb"><div class="hl">Норадреналин (NA)</div><div class="hv" id="hv-na">-</div><div class="hbar"><div class="hfill" id="hf-na"></div></div><div class="hs" id="hs-na"></div></div>
  <div class="hb"><div class="hl">Серотонин (5-HT)</div><div class="hv" id="hv-5ht">-</div><div class="hbar"><div class="hfill" id="hf-5ht"></div></div><div class="hs" id="hs-5ht"></div></div>
  <div class="hb"><div class="hl">Пластичность (s1)</div><div class="hv" id="hv-s1">-</div><div class="hbar"><div class="hfill" id="hf-s1"></div></div><div class="hs" id="hs-s1"></div></div>
  <div class="hb"><div class="hl">CYP2D6</div><div class="hv" id="hv-cyp">-</div><div class="hbar"><div class="hfill" id="hf-cyp"></div></div><div class="hs" id="hs-cyp"></div></div>
</div>

<script type="importmap">
{"imports":{"three":"https://unpkg.com/three@0.160.0/build/three.module.js","three/addons/":"https://unpkg.com/three@0.160.0/examples/jsm/"}}
</script>
<script type="module">
import * as THREE from 'three';
import { OrbitControls } from 'three/addons/controls/OrbitControls.js';
import { GLTFLoader } from 'three/addons/loaders/GLTFLoader.js';
import { EffectComposer } from 'three/addons/postprocessing/EffectComposer.js';
import { RenderPass } from 'three/addons/postprocessing/RenderPass.js';
import { UnrealBloomPass } from 'three/addons/postprocessing/UnrealBloomPass.js';
import { OutputPass } from 'three/addons/postprocessing/OutputPass.js';

var NTC = {'5-HT':'#60a5fa',DA:'#fbbf24',NA:'#34d399',ACh:'#c084fc','s1':'#f472b6',D3:'#f87171',Glu:'#e879f9'};

var ZR = {
  dlPFC:{SERT:2,NET:3,DAT:0,D1:3,D2:1,D3:0,'5HT1A':3,'5HT2A':3,'5HT2C':1,'5HT3':2,'5HT7':2,'a2A':3,s1:2,NMDA:3,'GABAA':2,note:'DAT отсутствует! NET убирает и NA и DA.'},
  vmPFC:{SERT:2,NET:2,DAT:0,D1:2,D2:1,'5HT1A':3,'5HT2A':2,'a2A':2,s1:2,NMDA:2,'GABAA':2,note:'Самореференция и эмоциональная регуляция'},
  ofc:{SERT:2,NET:2,DAT:0,D1:2,D2:2,'5HT2A':2,'5HT2C':2,'a2A':1,s1:1,'GABAA':2,note:'D2 выше чем в длПФК'},
  acc:{SERT:2,NET:2,DAT:1,D1:2,D2:2,'5HT1A':2,'5HT2A':2,'5HT7':3,'a2A':2,NMDA:3,'GABAA':2,note:'5-HT7 высокая - вортиоксетин ключевой'},
  insula:{SERT:1,NET:3,'a2A':2,'5HT1A':2,s1:1,NMDA:2,'GABAA':2,note:'NET высокая - NA критичен для интероцепции'},
  nac:{SERT:2,DAT:3,NET:1,D1:3,D2:3,D3:3,'5HT2C':2,'5HT1B':2,'GABAA':2,NMDA:2,note:'Core=D1 Shell=D3. DAT основной клиренс DA'},
  vta:{D2:3,D3:3,'5HT2C':3,'5HT1A':2,'GABAA':3,note:'D2/D3 АУТО. 5HT2C на ГАМК = серотониновый потолок DA'},
  lc:{'a2A':3,NET:2,'5HT1A':1,'GABAA':2,note:'a2A ауторецепторы контролируют NA-выброс'},
  amygdala:{SERT:3,NET:2,'5HT1A':3,'5HT2C':2,D1:1,D2:2,'a2A':2,s1:2,NMDA:3,'GABAA':3,note:'SERT высокая - SSRI эффективны. NMDA - реконсолидация (EMDR)'},
  hippo:{SERT:3,NET:2,'5HT1A':3,'5HT3':2,'5HT4':2,s1:3,NMDA:3,'a2A':2,'GABAA':2,note:'s1 ВЫСОКАЯ! s1->BDNF->LTP. NMDA->обучение'},
  parietal:{NET:2,'a2A':3,D1:1,'5HT2A':2,NMDA:2,note:'a2A - пространственное внимание'},
  cerebellum:{NET:2,D2:1,'GABAA':3,NMDA:2,note:'Пуркинье ГАМК. Тайминг'},
  brainstem:{NET:2,SERT:2,'5HT1A':2,'a2A':2,'GABAA':2,note:'Вегетативка'},
  raphe:{SERT:3,'5HT1A':3,'5HT1B':2,note:'Источник 5-HT. SERT на соме'},
  spinal:{SERT:2,NET:3,'5HT1A':2,'a2A':2,NMDA:2,note:'Нисходящее торможение боли NA+5-HT'}
};

var DRUGS = {
  sertraline:{n:'Золофт',c:'#60a5fa',s:'СЕРТ',doses:[25,50,75,100,150,200],def:100,u:'мг',warnDose:150,maxDose:200,warnText:'Серотониновый синдром при комбинации',ki:{SERT:0.29,DAT:25,NET:420,s1:35},s1t:'inv',
    z:{dlPFC:{nt:['5-HT'],fx:['SERT->5-HT','s1 ИНВЕРС->пластичность вниз'],i:3},amygdala:{nt:['5-HT'],fx:['SERT->5-HT->реактивность вниз вниз'],i:4},hippo:{nt:['5-HT','s1'],fx:['5HT1A->нейрогенез','s1 ИНВЕРС->LTP вниз!'],i:3,bad:1},vta:{nt:['5-HT'],fx:['5HT2C->ТОРМОЗ DA до 42%!'],i:4,bad:1},nac:{nt:['5-HT','DA'],fx:['5HT2C->DA вниз','DAT Ki=25->слабый DA вверх'],i:2,bad:1},vmPFC:{nt:['5-HT'],fx:['5-HT->эмоц.рег.'],i:2},acc:{nt:['5-HT'],fx:['руминация вниз'],i:2},raphe:{nt:['5-HT'],fx:['SERT->ауторег.'],i:3},brainstem:{nt:['5-HT'],fx:['вегетативка'],i:2},spinal:{nt:['5-HT'],fx:['боль вниз'],i:2}}},
  bupropion:{n:'Бупропион',c:'#fbbf24',s:'БУПРО',doses:[75,150,225,300,450],def:225,u:'мг',warnDose:300,maxDose:450,warnText:'Судорожный риск дозозависим',ki:{DAT:526,NET:2170},cyp:1,
    z:{dlPFC:{nt:['DA'],fx:['Слабый DA метаболит'],i:1},nac:{nt:['DA'],fx:['DAT 14-26% ПЭТ->D1'],i:2},lc:{nt:['NA'],fx:['NET метаболит'],i:2},brainstem:{nt:['NA'],fx:['NA->тонус'],i:3}}},
  atomoxetine:{n:'Атомоксетин',c:'#34d399',s:'АТОМ',doses:[5,10,18,25,40,60,80],def:10,u:'мг',warnDose:60,maxDose:80,warnText:'Гепатотоксичность — контроль печени',ki:{NET:5,SERT:77,DAT:1451},
    z:{dlPFC:{nt:['NA','DA'],fx:['NET->NA x3+DA x2.5 (нет DAT!)','a2A->HCN->рабочая память'],i:5},vmPFC:{nt:['NA'],fx:['NA->контроль эмоций'],i:2},acc:{nt:['NA'],fx:['NA->мониторинг ошибок'],i:3},insula:{nt:['NA'],fx:['NET->NA->интероцепция!','КЛЮЧЕВОЙ при диссоциации'],i:4},parietal:{nt:['NA'],fx:['a2A->я здесь'],i:4},lc:{nt:['NA'],fx:['NA->ауторег.'],i:2},cerebellum:{nt:['NA'],fx:['тайминг'],i:2},brainstem:{nt:['NA'],fx:['вегетативка'],i:2},spinal:{nt:['NA'],fx:['боль вниз'],i:1}}},
  vortioxetine:{n:'Вортиоксетин',c:'#a78bfa',s:'ВОРТ',doses:[5,10,15,20],def:10,u:'мг',ki:{SERT:1.6,'5HT3':3.7,'5HT1A':15,'5HT7':19,'5HT1B':33},
    z:{dlPFC:{nt:['DA','ACh','5-HT'],fx:['5HT3->DA+ACh','5HT1A->умный 5-HT','5HT7->гибкость'],i:4},acc:{nt:['5-HT'],fx:['5HT7->переключение'],i:3},amygdala:{nt:['5-HT'],fx:['5HT1A->страх вниз'],i:2},hippo:{nt:['5-HT','ACh'],fx:['5HT1A->нейрогенез','5HT3->ACh->память'],i:4},vta:{nt:['5-HT'],fx:['5HT1A->снятие потолка DA'],i:2},raphe:{nt:['5-HT'],fx:['мультимодальная модуляция'],i:3}}},
