var AD = {};
// Session persistence
function saveSession(){try{localStorage.setItem('cortexmd_scheme',JSON.stringify(AD))}catch(e){}}
function loadSession(){try{var s=localStorage.getItem('cortexmd_scheme');if(s){var p=JSON.parse(s);Object.keys(p).forEach(function(id){if(DRUGS[id])AD[id]=p[id]})}}catch(e){}}
loadSession();
var SR = null, BM = null, MK = {}, TL = [], CP = {};

var scene = new THREE.Scene();
var cam = new THREE.PerspectiveCamera(45,1,0.1,100);
cam.position.set(0,0.5,3.5);
var ren = new THREE.WebGLRenderer({antialias:true,alpha:true});
ren.setClearColor(0x000000,0);
ren.setPixelRatio(Math.min(devicePixelRatio,2));
ren.outputColorSpace = THREE.SRGBColorSpace;
ren.toneMapping = THREE.ACESFilmicToneMapping;
ren.toneMappingExposure = 1.5;
document.getElementById('cv').appendChild(ren.domElement);
var composer=new EffectComposer(ren);
composer.addPass(new RenderPass(scene,cam));
var bloomPass=new UnrealBloomPass(new THREE.Vector2(window.innerWidth,window.innerHeight),0.5,0.8,0.75);
composer.addPass(bloomPass);
composer.addPass(new OutputPass());
var ctrl = new OrbitControls(cam,ren.domElement);
ctrl.enableDamping = true; ctrl.dampingFactor = 0.05; ctrl.minDistance = 1.5; ctrl.maxDistance = 8;

scene.add(new THREE.AmbientLight(0x334455,0.4));
var dirL=new THREE.DirectionalLight(0x6e8caa,0.8);dirL.position.set(0,2,3);scene.add(dirL);
var warmL=new THREE.PointLight(0xff6633,0.3,5);warmL.position.set(0,-1,1);scene.add(warmL);
var rimL=new THREE.PointLight(0x8844ff,0.4,6);rimL.position.set(0,0.5,-2);scene.add(rimL);

function rsz(){var rp=document.getElementById('rp');var rpW=rp&&rp.classList.contains('open')?340:0;var w=innerWidth-280-rpW,h=innerHeight-48;cam.aspect=w/h;cam.updateProjectionMatrix();ren.setSize(w,h);composer.setSize(w,h);ren.domElement.style.marginLeft='280px'}
addEventListener('resize',rsz); rsz();

var mg = new THREE.Group(); scene.add(mg);

new GLTFLoader().load('brain.glb', function(g){
  BM=g.scene;var b=new THREE.Box3().setFromObject(BM);var c=b.getCenter(new THREE.Vector3());var s=b.getSize(new THREE.Vector3());var sc=2/Math.max(s.x,s.y,s.z);
  BM.position.sub(c);BM.scale.setScalar(sc);BM.position.y+=0.1;
  var _brainMesh=null;
  BM.traverse(function(ch){if(ch.isMesh){
    ch.material=new THREE.MeshPhysicalMaterial({color:0x8899aa,transparent:true,opacity:0.15,roughness:0.6,metalness:0.15,clearcoat:0.3,clearcoatRoughness:0.4,side:THREE.DoubleSide,depthWrite:false});
    if(!_brainMesh||ch.geometry.attributes.position.count>_brainMesh.geometry.attributes.position.count)_brainMesh=ch;
    var wireMat=new THREE.MeshBasicMaterial({color:0x6ee7b7,wireframe:true,transparent:true,opacity:0.06,depthWrite:false});
    var wireClone=ch.clone();wireClone.material=wireMat;wireClone.scale.multiplyScalar(1.002);BM.add(wireClone);
  }});
  scene.add(BM);
  if(_brainMesh){
    var positions=_brainMesh.geometry.attributes.position;
    var particleCount=Math.min(positions.count,5000);
    var step=Math.max(1,Math.floor(positions.count/particleCount));
    var particleGeo=new THREE.BufferGeometry();
    var particlePositions=new Float32Array(particleCount*3);
    for(var i=0,j=0;i<positions.count&&j<particleCount;i+=step,j++){
      particlePositions[j*3]=positions.getX(i);particlePositions[j*3+1]=positions.getY(i);particlePositions[j*3+2]=positions.getZ(i);
    }
    particleGeo.setAttribute('position',new THREE.BufferAttribute(particlePositions,3));
    var particleMat=new THREE.PointsMaterial({color:0xaabbcc,size:0.008,transparent:true,opacity:0.4,depthWrite:false,sizeAttenuation:true,blending:THREE.AdditiveBlending});
    var particleSystem=new THREE.Points(particleGeo,particleMat);
    particleSystem.position.copy(BM.position);particleSystem.rotation.copy(BM.rotation);particleSystem.scale.copy(BM.scale);
    scene.add(particleSystem);window._brainParticles=particleSystem;
  }
  initScene();
}, null, function(){
  var g=new THREE.SphereGeometry(1,64,48);var p=g.attributes.position;
  for(var i=0;i<p.count;i++){var x=p.getX(i)*0.75,y=p.getY(i),z=p.getZ(i)*0.9;if(y<-0.3)y*=0.5;var n=Math.sin(x*8)*Math.cos(z*6)*0.03;var r=Math.sqrt(x*x+y*y+z*z);p.setXYZ(i,x+x/r*n,y+y/r*n,z+z/r*n)}
  g.computeVertexNormals();
  BM=new THREE.Mesh(g,new THREE.MeshPhysicalMaterial({color:0x8899aa,transparent:true,opacity:0.15,roughness:0.6,metalness:0.15,clearcoat:0.3,clearcoatRoughness:0.4,side:THREE.DoubleSide,depthWrite:false}));
  var wireMat2=new THREE.MeshBasicMaterial({color:0x6ee7b7,wireframe:true,transparent:true,opacity:0.06,depthWrite:false});
  var wireClone2=BM.clone();wireClone2.material=wireMat2;wireClone2.scale.multiplyScalar(1.002);scene.add(wireClone2);
  scene.add(BM);
  var positions2=g.attributes.position;var pc2=Math.min(positions2.count,5000);var step2=Math.max(1,Math.floor(positions2.count/pc2));
  var pGeo2=new THREE.BufferGeometry();var pPos2=new Float32Array(pc2*3);
  for(var i2=0,j2=0;i2<positions2.count&&j2<pc2;i2+=step2,j2++){pPos2[j2*3]=positions2.getX(i2);pPos2[j2*3+1]=positions2.getY(i2);pPos2[j2*3+2]=positions2.getZ(i2)}
  pGeo2.setAttribute('position',new THREE.BufferAttribute(pPos2,3));
  var pMat2=new THREE.PointsMaterial({color:0xaabbcc,size:0.008,transparent:true,opacity:0.4,depthWrite:false,sizeAttenuation:true,blending:THREE.AdditiveBlending});
  var pSys2=new THREE.Points(pGeo2,pMat2);scene.add(pSys2);window._brainParticles=pSys2;
  initScene();
});

function initScene(){
  Object.entries(RG).forEach(function(e){var id=e[0],r=e[1];
    var m=new THREE.Mesh(new THREE.SphereGeometry(0.035,16,16),new THREE.MeshPhysicalMaterial({color:new THREE.Color(r.c),emissive:new THREE.Color(r.c),emissiveIntensity:0.8,transparent:true,opacity:0.95,roughness:0.2}));
    m.position.set(r.p[0],r.p[1],r.p[2]);m.userData={rid:id};mg.add(m);MK[id]=m;
    var ring=new THREE.Mesh(new THREE.RingGeometry(0.045,0.065,32),new THREE.MeshBasicMaterial({color:new THREE.Color(r.c),transparent:true,opacity:0.25,side:THREE.DoubleSide}));
    ring.position.copy(m.position);ring.userData={rid:id,isR:true};mg.add(ring);
  });
  TR.forEach(function(t){var a=RG[t.f],b=RG[t.t];
    var cv=new THREE.QuadraticBezierCurve3(new THREE.Vector3(a.p[0],a.p[1],a.p[2]),new THREE.Vector3((a.p[0]+b.p[0])/2,(a.p[1]+b.p[1])/2+0.12,(a.p[2]+b.p[2])/2),new THREE.Vector3(b.p[0],b.p[1],b.p[2]));
    var geo=new THREE.BufferGeometry().setFromPoints(cv.getPoints(40));
    var mat=new THREE.LineBasicMaterial({color:new THREE.Color(NTC[t.nt]||'#666'),transparent:true,opacity:0});
    var ln=new THREE.Line(geo,mat);ln.userData={tr:t};scene.add(ln);TL.push(ln);
  });
  buildUI(); uAll();
}

var rc=new THREE.Raycaster(), ms=new THREE.Vector2();
ren.domElement.addEventListener('click',function(ev){
  var r=ren.domElement.getBoundingClientRect();
  ms.x=((ev.clientX-r.left)/r.width)*2-1; ms.y=-((ev.clientY-r.top)/r.height)*2+1;
  rc.setFromCamera(ms,cam);var h=rc.intersectObjects(mg.children);
  if(h.length>0&&h[0].object.userData.rid){
    var id=h[0].object.userData.rid;
    if(SR===id){SR=null;closeZonePopup();uAll();return}
    SR=id;uAll();
    // Show popup at screen position of marker
    var obj=h[0].object;var vec=new THREE.Vector3();obj.getWorldPosition(vec);vec.project(cam);
    var cx=(vec.x*0.5+0.5)*r.width+r.left;var cy=(-vec.y*0.5+0.5)*r.height+r.top;
    showZonePopup(id,{x:cx,y:cy});
  }else{SR=null;closeZonePopup();uAll()}
});
ren.domElement.addEventListener('mousemove',function(ev){
  var r=ren.domElement.getBoundingClientRect();ms.x=((ev.clientX-r.left)/r.width)*2-1;ms.y=-((ev.clientY-r.top)/r.height)*2+1;
  rc.setFromCamera(ms,cam);var h=rc.intersectObjects(mg.children);var tt=document.getElementById('tooltip');
  if(h.length>0&&h[0].object.userData.rid){var id=h[0].object.userData.rid,rg=RG[id];
    tt.style.display='block';tt.style.left=(ev.clientX+15)+'px';tt.style.top=(ev.clientY-10)+'px';
    tt.innerHTML='<b>'+rg.f+'</b><br><span style="color:#94a3b8">'+rg.fn+'</span>';ren.domElement.style.cursor='pointer';
  }else{tt.style.display='none';ren.domElement.style.cursor='grab'}
});

function cypVal(){var t=0;var d=AD.bupropion||0;t+=d>=300?80:d>=225?70:d>=150?45:d>=75?20:0;
  if(AD.fluoxetine)t+=75;return Math.min(95,t)}
function realD(id){var b=AD[id];if(!b)return 0;var c=cypVal();var d=DRUGS[id];
  if(id==='atomoxetine')return b*(1+c/100*4);if(id==='vortioxetine')return b*(1+c/100*1.1);
  if(d&&d.cyp2d6s)return b*(1+c/100*d.cyp2d6s);return b}
function occ(id,rec){var d=DRUGS[id];if(!d||!d.ki||!d.ki[rec])return 0;var dose=realD(id);var ki=d.ki[rec];var f=id==='pramipexole'?0.5:id==='cariprazine'?0.3:id==='guanfacine'?2:1;return(dose/(dose+ki*f))*100}

var NT_REC={'DA':['DAT','D3','D2'],'NA':['NET','a2A','alpha1'],'5-HT':['SERT','5HT3','5HT1A','5HT7','5HT1B'],'s1':['s1'],'D3':['D3','D2'],'Glu':['NMDA'],'ACh':['AChE','5HT3']};
function drugOcc(did,nt){var d=DRUGS[did];if(!d)return 0;var recs=NT_REC[nt]||[];var best=0;for(var r=0;r<recs.length;r++){if(d.ki&&d.ki[recs[r]]!==undefined){var o=occ(did,recs[r]);if(o>best)best=o}}if(best>0)return best;return Math.min(100,(realD(did)/(d.def||1))*50)}
function zH(zid,nt){var t=65;Object.keys(AD).forEach(function(did){var d=DRUGS[did];if(!d)return;var zf=d.z?d.z[zid]:null;if(!zf)return;if(zf.nt.indexOf(nt)<0&&nt!=='s1')return;if(nt==='s1'&&zf.nt.indexOf('s1')<0)return;var occupancy=drugOcc(did,nt);var maxEff=zf.i*8;var delta=(occupancy/100)*maxEff;if(zf.bad)delta=-delta*0.7;t+=delta});return Math.max(0,Math.min(250,t))}
function gH(nt){var zs=Object.keys(RG);var s=0,c=0;var m={DA:['DA','D3'],NA:['NA'],'5-HT':['5-HT'],s1:['s1']};var nts=m[nt]||[nt];
nts.forEach(function(n){zs.forEach(function(z){var h=zH(z,n);if(h!==65||Object.keys(AD).some(function(d){var dr=DRUGS[d];return dr&&dr.z&&dr.z[z]&&dr.z[z].nt.indexOf(n)>=0})){s+=h;c++}})});return c>0?s/c:65}
function hCol(v){return v<60?'#ef4444':v<80?'#f59e0b':v<=160?'#22c55e':v<=200?'#f59e0b':'#ef4444'}
function hSt(v){return v<60?'Дефицит':v<80?'Ниже нормы':v<=160?'Оптимум':v<=200?'Повышен':'Перегруз'}

function uAll(){uVis();uInfo();uConf();uHP();uAS();buildDC();updatePanelBadge();
  if(DSEL)uDefInfo();
  if(document.getElementById('s1overlay').classList.contains('show'))buildS1SVG()}

function uVis(){Object.entries(MK).forEach(function(e){var id=e[0],m=e[1];
  var fx=[];Object.keys(AD).forEach(function(d){var dr=DRUGS[d];if(dr&&dr.z&&dr.z[id])fx.push({d:d,bad:dr.z[id].bad,i:dr.z[id].i})});
  var it=fx.reduce(function(s,x){return s+x.i},0);var bd=fx.some(function(x){return x.bad});var sl=SR===id;
  m.scale.setScalar(it>0?1+it*0.06:0.5);
  if(it>0){var avg=zH(id,'DA')*0.3+zH(id,'5-HT')*0.3+zH(id,'NA')*0.3+zH(id,'s1')*0.1;m.material.emissive.set(bd?'#ff4444':hCol(avg));m.material.emissiveIntensity=sl?2:0.5+it*0.1;m.material.opacity=sl?1:0.85}
  else{m.material.emissive.set(RG[id].c);m.material.emissiveIntensity=0.1;m.material.opacity=0.3}
  // Deficit zone highlighting
  if(DSEL){var df=DEFICITS.find(function(x){return x.id===DSEL});if(df){var isDZ=df.zones.indexOf(id)>=0;
    if(isDZ){m.material.emissiveIntensity=sl?2.5:1.8;m.scale.setScalar(Math.max(m.scale.x,1.5));
      if(df.status==='critical'){m.material.emissive.set('#ff4444');m.material.opacity=0.7+0.3*Math.sin(Date.now()*0.005)}}
    else{m.material.opacity*=0.4;m.material.emissiveIntensity*=0.3}}}});
  TL.forEach(function(l){var t=l.userData.tr;var a=false;
    if(t.nt==='DA')a=Object.keys(AD).some(function(d){return['bupropion','pramipexole','cariprazine','aripiprazole','brexpiprazole','methylphenidate','lisdexamfetamine','modafinil','selegiline_oral','amisulpride_low','levodopa','auvelity'].indexOf(d)>=0});
    if(t.nt==='NA')a=Object.keys(AD).some(function(d){return['atomoxetine','bupropion','duloxetine','guanfacine','desipramine','nortriptyline','protriptyline','reboxetine','milnacipran','levomilnacipran','venlafaxine','desvenlafaxine','quetiapine','lisdexamfetamine','brexpiprazole'].indexOf(d)>=0});
    if(t.nt==='5-HT')a=Object.keys(AD).some(function(d){return['sertraline','vortioxetine','duloxetine','escitalopram','fluvoxamine','fluoxetine','venlafaxine','desvenlafaxine','milnacipran','levomilnacipran','amitriptyline','dextromethorphan'].indexOf(d)>=0});
    l.material.opacity=a?0.4:0})}

function uInfo(){var el=document.getElementById('ri');
  if(!SR){el.innerHTML='';return}
  var r=RG[SR];
  // Zone header with colored background
  var h='<div class="zone-header-card" style="background:'+r.c+'18"><div class="zone-header-title">'+r.f+'</div><div class="zone-header-subtitle">'+r.fn+'</div></div>';
  // Active drug effects — simplified, large
  var fx=[];Object.keys(AD).forEach(function(d){var dr=DRUGS[d];if(dr&&dr.z&&dr.z[SR])fx.push({drug:d,data:dr.z[SR]})});
  if(fx.length>0){h+='<div class="panel-section-title">Активные эффекты</div>';
    fx.forEach(function(e){var d=DRUGS[e.drug];var isBad=e.data.bad;
      var arrow=isBad?'\u2193':'\u2191';var cls=isBad?'down':'up';
      if(e.data.i<=1){arrow='\u2192';cls='neutral'}
      h+='<div class="panel-effect"><div class="panel-effect-icon '+cls+'">'+arrow+'</div>';
      h+='<span class="panel-effect-drug" style="color:'+d.c+'">'+d.s+'</span>';
      h+='<span class="panel-effect-desc">'+e.data.fx[0]+'</span></div>'});
  }else{h+='<div style="font-size:12px;color:var(--text-muted);margin-top:8px;font-style:italic">Нет активных препаратов для этой зоны</div>'}
  // σ1 button
  var hasS1=Object.keys(AD).some(function(d){var dr=DRUGS[d];return dr&&dr.s1t});
  if(hasS1)h+='<div class="cvbtn" onclick="showS1()">\u03C31 Клеточный уровень \u2192</div>';
  // Related deficits
  var rd=DEFICITS.filter(function(d){return d.zones.indexOf(SR)>=0});
  if(rd.length>0){h+='<div class="panel-section-title">Связанные дефициты</div>';
    rd.forEach(function(d){var sc=d.status==='critical'?'var(--status-danger)':d.status==='working'?'var(--status-warning)':'var(--status-optimal)';
      var tc=defTotalCov(d);var cc=covCol(tc);
      h+='<div style="display:flex;align-items:center;gap:8px;padding:6px 8px;margin-bottom:4px;border-radius:8px;cursor:pointer;background:rgba(255,255,255,0.02);transition:background 0.2s" onclick="selDef(\''+d.id+'\')">';
      h+='<span style="font-size:16px">'+d.icon+'</span><span style="font-size:12px;color:var(--text-primary);flex:1;font-weight:500">'+d.st+'</span>';
      h+='<span style="font-family:var(--font-mono);font-size:11px;color:'+cc+'">'+tc+'%</span>';
      h+='<span style="width:8px;height:8px;border-radius:50%;background:'+sc+'"></span></div>'})
  }
  el.innerHTML=h}

function uConf(){var el=document.getElementById('cfb');var c=[],cr=[];
  var ssris=['sertraline','escitalopram','fluoxetine','fluvoxamine'];
  var snris=['duloxetine','venlafaxine','desvenlafaxine','milnacipran','levomilnacipran'];
  var seroAll=ssris.concat(snris);
  var hasSSRI=ssris.some(function(d){return AD[d]!==undefined});
  var hasSNRI=snris.some(function(d){return AD[d]!==undefined});
  // CRITICAL: DXM + SSRI/SNRI
  if((AD.dextromethorphan!==undefined||AD.auvelity!==undefined)&&seroAll.some(function(d){return AD[d]!==undefined}))
    cr.push('<span style="color:#ef4444">⛔ DXM НЕЛЬЗЯ с SSRI/SNRI — серотониновый синдром!</span>');
  // CRITICAL: Selegiline + DXM
  if(AD.selegiline_oral!==undefined&&(AD.dextromethorphan!==undefined||AD.auvelity!==undefined))
    cr.push('<span style="color:#ef4444">⛔ Селегилин ПРОТИВОПОКАЗАН с DXM</span>');
  // CRITICAL: Mucuna + MAOI
  if(AD.mucuna!==undefined&&AD.selegiline_oral!==undefined)
    cr.push('<span style="color:#ef4444">⛔ Мукуна (L-DOPA) + ИМАО = опасно</span>');
  // Selegiline + SSRI caution
  if(AD.selegiline_oral!==undefined&&hasSSRI)c.push('⚠️ Селегилин: осторожность с SSRI');
  // Existing conflicts
  if(AD.sertraline&&AD.bupropion)c.push('Серт 5HT2C → DA VTA вниз 30-42%');
  // σ1 competition: inverse agonist + agonists
  var s1inv=Object.keys(AD).some(function(d){return DRUGS[d]&&DRUGS[d].s1t==='inv'});
  var s1ag=Object.keys(AD).filter(function(d){return DRUGS[d]&&DRUGS[d].s1t==='ag'});
  if(s1inv&&s1ag.length>0)c.push('⚡ σ1-конфликт: инверсный агонист подавляет каскад пластичности');
  // Progesterone blocks σ1
  if(AD.progesterone!==undefined&&s1ag.length>0)c.push('⚠️ Прогестерон — σ1-АНТАГОНИСТ. Блокирует σ1-агонисты');
  // Triple NET overload
  var netDrugs=['bupropion','duloxetine','atomoxetine','desipramine','nortriptyline','protriptyline','reboxetine','milnacipran','levomilnacipran','venlafaxine'].filter(function(d){return AD[d]!==undefined});
  if(netDrugs.length>=3)c.push('⚠️ Тройной+ NET ('+netDrugs.length+' препаратов) → NA-перегруз');
  // CYP2D6 cascade
  var cy=cypVal();if(cy>0){var cs='CYP2D6 ингиб. '+cy+'%: ';var cyps=[];
    Object.keys(AD).forEach(function(id){var d=DRUGS[id];if(d&&d.cyp2d6s){var r=realD(id);if(r!==AD[id])cyps.push(d.s+'→'+r.toFixed(0)+d.u)}});
    if(AD.atomoxetine)cyps.push('АТОМ→'+realD('atomoxetine').toFixed(0)+'мг');
    if(AD.vortioxetine)cyps.push('ВОРТ→'+realD('vortioxetine').toFixed(0)+'мг');
    if(cyps.length)c.push(cs+cyps.join(', '))}
  // Bupropion + DRPA dosing
  if(AD.bupropion&&(AD.aripiprazole||AD.brexpiprazole))c.push('⚠️ С бупропионом: ПОЛОВИННАЯ доза арипипразола/брексипразола');
  // Modafinil CYP3A4 induction
  if(AD.modafinil&&AD.cariprazine)c.push('⚠️ Модафинил CYP3A4 индуктор → снижает карипразин');
  // Fluvoxamine CYP1A2/2C19
  if(AD.fluvoxamine&&(AD.lamotrigine||AD.duloxetine))c.push('⚠️ Флувоксамин CYP1A2/2C19 → повышает ламотриджин/дулоксетин');
  // SAMe + SSRI
  if(AD.same&&hasSSRI)c.push('SAMe+SSRI: редкий риск серотонинового синдрома');
  // Pramipexole + cariprazine
  if(AD.pramipexole!==undefined&&AD.cariprazine!==undefined)c.push('Прам+карипразин: конкуренция D3');
  // Fluoxetine long half-life
  if(AD.fluoxetine&&Object.keys(AD).length>2)c.push('Флуоксетин: Т½ очень длинный, мощный CYP2D6 ингибитор');
  var html='';
  if(cr.length)html+='<div class="cb" style="border-color:#7f1d1d;background:rgba(127,29,29,.2)"><div class="cbt" style="color:#ef4444">КРИТИЧЕСКИЕ ('+cr.length+')</div>'+cr.map(function(x){return'<div class="ci">'+x+'</div>'}).join('')+'</div>';
  if(c.length)html+='<div class="cb"><div class="cbt">Предупреждения ('+c.length+')</div>'+c.map(function(x){return'<div class="ci">'+x+'</div>'}).join('')+'</div>';
  el.innerHTML=html}

function uHP(){['DA','NA','5-HT','s1'].forEach(function(nt){var k=nt==='5-HT'?'5ht':nt==='s1'?'s1':nt.toLowerCase();var v=Object.keys(AD).length>0?gH(nt):65;var c=hCol(v);
  document.getElementById('hv-'+k).textContent=v.toFixed(0)+'%';document.getElementById('hv-'+k).style.color=c;
  document.getElementById('hf-'+k).style.width=Math.min(100,v/2)+'%';document.getElementById('hf-'+k).style.background=c;
  document.getElementById('hs-'+k).textContent=hSt(v);document.getElementById('hs-'+k).style.color=c});
  var cy=cypVal();var cc=cy>60?'#ef4444':cy>30?'#f59e0b':'#22c55e';
  document.getElementById('hv-cyp').textContent=cy+'%';document.getElementById('hv-cyp').style.color=cc;
  document.getElementById('hf-cyp').style.width=cy+'%';document.getElementById('hf-cyp').style.background=cc;
  document.getElementById('hs-cyp').textContent=cy>60?'Сильное':cy>30?'Среднее':cy>0?'Слабое':'Нет';document.getElementById('hs-cyp').style.color=cc}

function uAS(){}

function buildUI(){buildP();buildD();buildDC();uAll()}
function buildP(){var el=document.getElementById('presets');var h='';Object.keys(PRESETS).forEach(function(id){h+='<button class="pb" onclick="aP(\''+id+'\')">'+PRESETS[id].l+'</button>'});
  Object.keys(CP).forEach(function(n){h+='<button class="pb" style="border-color:#064e3b;color:#34d399" onclick="aCP(\''+n+'\')">'+n+'</button>'});el.innerHTML=h}

function filteredDrugs(){var sq=window._dsq||'';var ids=Object.keys(DRUGS);
  if(CCAT!=='all'){var cd=DCAT[CCAT];if(cd&&cd.d)ids=ids.filter(function(id){return cd.d.indexOf(id)>=0})}
  if(sq){sq=sq.toLowerCase();ids=ids.filter(function(id){var d=DRUGS[id];return d.n.toLowerCase().indexOf(sq)>=0||d.s.toLowerCase().indexOf(sq)>=0||id.toLowerCase().indexOf(sq)>=0})}
  return ids}
function buildDTabs(){var el=document.getElementById('dtabs');
  var h='';Object.keys(DCAT).forEach(function(k){h+='<div class="dtab '+(CCAT===k?'act':'')+'" onclick="setCCAT(\''+k+'\')">'+DCAT[k].l+'</div>'});el.innerHTML=h}
function buildDList(){var el=document.getElementById('dl');if(!el)return;var ids=filteredDrugs();
  var h='<div class="dg">';ids.forEach(function(id){var d=DRUGS[id];var inScheme=AD.hasOwnProperty(id);
    h+='<div class="di'+(inScheme?' in-scheme':'')+'" style="--c:'+d.c+'" onclick="addFromCatalog(\''+id+'\')" title="'+d.n+(inScheme?' (добавлен)':'')+'"><div class="ddt"'+(inScheme?' style="background:var(--c);box-shadow:0 0 8px var(--c)"':'')+'></div><span>'+d.s+'</span></div>'});h+='</div>';
  h+='<div class="disclaimer">Образовательный инструмент. НЕ медицинский совет.</div>';
  el.innerHTML=h}
function buildD(){buildDTabs();buildDList();buildActiveScheme()}

function buildActiveScheme(){
  var el=document.getElementById('active-scheme');if(!el)return;
  var cnt=document.getElementById('scheme-count');
  var ids=Object.keys(AD);
  if(cnt)cnt.textContent=ids.length>0?ids.length+' шт':'';
  if(ids.length===0){el.innerHTML='<div class="empty-scheme">Добавьте препараты из каталога ниже</div>';return}
  var h='<div class="scheme-grid">';
  ids.forEach(function(id){
    var d=DRUGS[id];if(!d)return;
    var dose=AD[id];var rd=realD(id);
    var hasWarn=d.warnDose&&dose>=d.warnDose;
    var mn=d.doses[0],mx=d.doses[d.doses.length-1];
    var step=d.doses.length>1?d.doses[1]-d.doses[0]:1;
    h+='<div class="scheme-card" style="--c:'+d.c+'">';
    h+='<div class="scheme-header"><span class="scheme-dot" style="background:'+d.c+'"></span>';
    h+='<span class="scheme-name">'+d.s+'</span>';
    h+='<button class="scheme-remove" onclick="event.stopPropagation();removeFromScheme(\''+id+'\')" title="Убрать">&times;</button></div>';
    h+='<div class="scheme-dose"><span id="sdv-'+id+'">'+dose+'</span> '+d.u+'</div>';
    if(rd&&Math.abs(rd-dose)>1)h+='<div class="scheme-real-dose">реально ~'+Math.round(rd)+d.u+'</div>';
    if(hasWarn)h+='<div class="scheme-warning">\u26A0</div>';
    if(hasWarn&&d.warnText)h+='<div class="scheme-warn-text">'+d.warnText+'</div>';
    h+='<input type="range" class="scheme-slider" min="'+mn+'" max="'+mx+'" step="'+step+'" value="'+dose+'" style="accent-color:'+d.c+'" oninput="updateDose(\''+id+'\',this.value)">';
    h+='</div>';
  });
  h+='</div>';el.innerHTML=h
}

// === DEFICIT CARDS ===
function defCov(df){
  return df.needs.map(function(n){
    if(n.coveredBy.length===0)return{target:n.target,cov:-1,covering:[],blocking:[],np:true,desc:n.desc};
    var covering=n.coveredBy.filter(function(id){return AD[id]!==undefined});
    var blocking=(n.blockedBy||[]).filter(function(id){return AD[id]!==undefined});
    var cov=Math.min(100,covering.length*40);
    if(blocking.length>0&&cov>0)cov=Math.round(cov*0.5);
    return{target:n.target,cov:cov,covering:covering,blocking:blocking,np:false,desc:n.desc}
  })
}
function defTotalCov(df){
  var covs=defCov(df);var pharma=covs.filter(function(c){return!c.np});
  if(pharma.length===0)return 0;
  return Math.round(pharma.reduce(function(s,c){return s+c.cov},0)/pharma.length)
}
function covCol(pct){
  if(pct<=20)return'#ef4444';if(pct<=40)return'#f97316';if(pct<=60)return'#f59e0b';if(pct<=80)return'#22c55e';return'#10b981'}
function defNTs(df){
  var nts={};df.defs.forEach(function(d){nts[d.nt]=1});
  return Object.keys(nts).map(function(nt){
    var col=NTC[nt==='s1'?'s1':nt]||'#999';
    return'<span style="display:inline-block;font-size:8px;padding:1px 4px;border-radius:3px;background:'+col+'22;color:'+col+';font-weight:600;font-family:var(--font-mono)">'+nt+'\u2193</span>'
  }).join(' ')
}

function buildDC(){
  var el=document.getElementById('dfc');if(!el)return;
  var h='';
  DEFICITS.forEach(function(df){
    var tc=defTotalCov(df);
    var cc=covCol(tc);
    var isSel=DSEL===df.id;
    var isExp=isSel;
    h+='<div class="dc '+df.status+(isSel?' sel':'')+(isExp?' exp':'')+'" onclick="selDef(\''+df.id+'\')">';
    // header
    h+='<div class="dc-head"><span class="dc-icon">'+df.icon+'</span><span class="dc-name">'+df.st+'</span><span class="dc-status '+df.status+'"></span></div>';
    // zone chips
    h+='<div class="dc-zones">';
    df.zones.forEach(function(z){var rg=RG[z];if(rg)h+='<span class="zc" onmouseenter="hoverDZ(\''+z+'\')" onmouseleave="unhoverDZ()" onclick="event.stopPropagation();clickDZ(\''+z+'\')">'+rg.n+'</span>'});
    h+='</div>';
    // coverage bar
    h+='<div class="dc-cov"><div class="dc-cbar"><div class="dc-cfill" style="width:'+tc+'%;background:'+cc+'"></div></div><span class="dc-cpct" style="color:'+cc+'">'+tc+'%</span><span class="dc-cnts">'+defNTs(df)+'</span></div>';
    // dynamic blocking warnings
    var blockers=[];df.needs.forEach(function(n){(n.blockedBy||[]).forEach(function(bid){if(AD[bid]!==undefined&&blockers.indexOf(bid)<0)blockers.push(bid)})});
    if(blockers.length>0){h+='<div class="dc-block">\u26A0 Блокирует: '+blockers.map(function(id){return DRUGS[id]?DRUGS[id].s:id}).join(', ')+'</div>'}

    // expanded body
    h+='<div class="dc-body">';
    h+='<div class="dc-desc">'+df.desc+'</div>';

    // deficits
    h+='<div class="dc-sec">Дефициты</div>';
    df.defs.forEach(function(d){
      var rg=RG[d.zone];var zn=rg?rg.n:d.zone;
      var ntc=NTC[d.nt==='s1'?'s1':d.nt]||'#999';
      h+='<div class="dc-def"><div class="dc-def-title" style="color:'+ntc+'">'+d.nt+' в '+zn+'</div>';
      h+='<div class="dc-def-mech">'+d.mech+'</div>';
      if(d.src)h+='<div class="dc-def-src">'+d.src+'</div>';
      h+='</div>'
    });

    // coverage details
    h+='<div class="dc-sec">Покрытие схемой</div>';
    var covs=defCov(df);
    covs.forEach(function(c){
      if(c.np){
        h+='<div class="dc-need-np">'+c.target+': '+c.desc+'</div>';return
      }
      var cc2=covCol(c.cov);
      h+='<div class="dc-need"><div class="dc-need-title">'+c.target+'</div>';
      h+='<div class="dc-need-bar"><div class="dc-need-fill"><div style="width:'+c.cov+'%;background:'+cc2+'"></div></div><span class="dc-need-pct" style="color:'+cc2+'">'+c.cov+'%</span></div>';
      if(c.covering.length)h+='<div class="dc-need-drugs">'+c.covering.map(function(id){return DRUGS[id]?DRUGS[id].s:id}).join(', ')+'</div>';
      if(c.blocking.length)h+='<div class="dc-need-block">\u26A0 Блокирует: '+c.blocking.map(function(id){return DRUGS[id]?DRUGS[id].s:id}).join(', ')+'</div>';
      h+='</div>'
    });

    // AI placeholder
    h+='<div class="dc-ai"><div class="dc-ai-text">AI-анализ будет доступен в следующей версии</div></div>';

    // footer
    h+='<div class="dc-foot"><select class="dc-stsel" onclick="event.stopPropagation()" onchange="chDefSt(\''+df.id+'\',this.value)">';
    ['critical','working','compensated'].forEach(function(s){
      var lb=s==='critical'?'Критично':s==='working'?'В работе':'Компенсировано';
      h+='<option value="'+s+'"'+(df.status===s?' selected':'')+'>'+lb+'</option>'
    });
    h+='</select><span class="dc-del" onclick="event.stopPropagation();delDef(\''+df.id+'\')">\u{1F5D1} Удалить</span></div>';

    h+='</div>'; // dc-body
    h+='</div>'; // dc
  });
  el.innerHTML=h
}

window.selDef=function(id){
  if(DSEL===id){DSEL=null;SR=null}else{DSEL=id}
  buildDC();uVis();uDefInfo()
};
window.hoverDZ=function(zid){
  if(!MK[zid])return;
  MK[zid].material.emissiveIntensity=2.5;MK[zid].scale.setScalar(1.8)
};
window.unhoverDZ=function(){uVis()};
var _defOverlayOn=false;
window.toggleDefView=function(){var btn=document.getElementById('defToggle');_defOverlayOn=!_defOverlayOn;btn.classList.toggle('active',_defOverlayOn);
  if(_defOverlayOn){
    btn.textContent='\u{1F534} Скрыть дефициты';
    // Save original marker states and apply deficit overlay
    DEFICITS.forEach(function(df){if(df.status==='compensated')return;
      df.zones.forEach(function(zid){var m=MK[zid];if(!m)return;
        if(!m.userData._defOrig){m.userData._defOrig={s:m.scale.clone(),e:m.material.emissive.clone(),ei:m.material.emissiveIntensity,o:m.material.opacity}}
        m.scale.setScalar(Math.max(m.scale.x,1.5));
        var col=df.status==='critical'?0xff0000:0xff9900;
        m.material.emissive.set(col);m.material.emissiveIntensity=0.8;m.material.opacity=0.9})});
    // Also expand deficit section in left panel
    var dfcEl=document.getElementById('dfc');if(dfcEl){var sec=dfcEl.closest('.section');if(sec){var sb=sec.querySelector('.sb');var sa=sec.querySelector('.sa');if(sb&&!sb.classList.contains('open')){sb.classList.add('open');if(sa)sa.classList.add('open')}}}
  }else{
    btn.textContent='\u0414\u0435\u0444\u0438\u0446\u0438\u0442\u044B';
    // Restore original marker states
    Object.keys(MK).forEach(function(zid){var m=MK[zid];if(m.userData._defOrig){var o=m.userData._defOrig;m.scale.copy(o.s);m.material.emissive.copy(o.e);m.material.emissiveIntensity=o.ei;m.material.opacity=o.o;delete m.userData._defOrig}});
    DSEL=null;buildDC();uVis()
  }};
window.clickDZ=function(zid){SR=zid;uAll()};
window.chDefSt=function(id,st){
  var d=DEFICITS.find(function(x){return x.id===id});if(d)d.status=st;buildDC()
};
window.delDef=function(id){
  var i=DEFICITS.findIndex(function(x){return x.id===id});
  if(i>=0){DEFICITS.splice(i,1);if(DSEL===id)DSEL=null;buildDC();uVis()}
};

function uDefInfo(){
  if(!DSEL)return;
  var df=DEFICITS.find(function(x){return x.id===DSEL});if(!df)return;
  // highlight zones on brain
  df.zones.forEach(function(zid){
    if(!MK[zid])return;
    var col=df.status==='critical'?'#ef4444':df.status==='working'?'#f59e0b':'#22c55e';
    MK[zid].material.emissive.set(col);
    MK[zid].material.emissiveIntensity=df.status==='critical'?1.5:1;
    MK[zid].material.opacity=0.9;
    MK[zid].scale.setScalar(1.3)
  })
}

window.buildDList=buildDList;window.buildDTabs=buildDTabs;window.buildActiveScheme=buildActiveScheme;
window.setCCAT=function(k){CCAT=k;buildDTabs();buildDList()};
window.setDSQ=function(v){window._dsq=v;buildDList()};
window.tSec=function(h){var b=h.nextElementSibling;var a=h.querySelector('.sa');b.classList.toggle('open');a.classList.toggle('open')};
window.tD=function(id){if(AD.hasOwnProperty(id))delete AD[id];else AD[id]=DRUGS[id].def;buildDList();uAll();saveSession()};
window.addFromCatalog=function(id){if(AD.hasOwnProperty(id))return;AD[id]=DRUGS[id].def;buildActiveScheme();buildDList();uAll();saveSession()};
window.removeFromScheme=function(id){delete AD[id];buildActiveScheme();buildDList();uAll();saveSession()};
window.updateDose=function(id,v){var dose=parseFloat(v);AD[id]=dose;var el=document.getElementById('sdv-'+id);if(el)el.textContent=v;
  var d=DRUGS[id];if(el){var card=el.closest('.scheme-card');if(card){
    // Update real dose inline
    var rd=realD(id);var rdEl=card.querySelector('.scheme-real-dose');
    if(rd&&Math.abs(rd-dose)>1){if(rdEl){rdEl.textContent='реально ~'+Math.round(rd)+d.u}else{var sp=document.createElement('div');sp.className='scheme-real-dose';sp.textContent='реально ~'+Math.round(rd)+d.u;card.querySelector('.scheme-dose').insertAdjacentElement('afterend',sp)}}
    else if(rdEl){rdEl.remove()}
    // Update warning inline
    if(d&&d.warnDose){var w=card.querySelector('.scheme-warning');var wt=card.querySelector('.scheme-warn-text');if(w)w.style.display=dose>=d.warnDose?'block':'none';if(wt)wt.style.display=dose>=d.warnDose?'block':'none'}
  }}
  uAll();saveSession()};
window.toggleCatalog=function(){var sec=document.getElementById('catalog-section');var arr=document.getElementById('catalog-toggle');sec.classList.toggle('open');arr.textContent=sec.classList.contains('open')?'\u25B2':'\u25BC'};
window.cD=function(id,v){var dose=parseFloat(v);AD[id]=dose;var el=document.getElementById('dv-'+id);if(el)el.textContent=v;
  var d=DRUGS[id];if(d&&d.warnDose){var w=document.getElementById('dw-'+id);if(w){w.classList.toggle('show',dose>=d.warnDose);w.classList.toggle('danger',dose>=d.maxDose)}}
  uAll()};
window.aP=function(id){AD={};var d=PRESETS[id].d;Object.keys(d).forEach(function(k){AD[k]=d[k]});SR=null;buildDList();buildActiveScheme();uAll();saveSession()};
window.aCP=function(n){AD={};var d=CP[n];Object.keys(d).forEach(function(k){AD[k]=d[k]});SR=null;buildDList();buildActiveScheme();uAll();saveSession()};
window.saveP=function(){var n=prompt('Название:');if(!n)return;CP[n]={};Object.keys(AD).forEach(function(k){CP[n][k]=AD[k]});buildP()};

document.getElementById('opsl').addEventListener('input',function(e){var o=e.target.value/100;if(BM)BM.traverse(function(c){if(c.isMesh)c.material.opacity=o})});

// === σ1 CASCADE ===
var S1N=[
  {id:'s1r',l:'σ1R',d:'Сигма-1 рецептор на мембране ЭР (MAM). При покое связан с BiP.',x:400,y:40,w:60},
  {id:'bip',l:'BiP',d:'Шаперон BiP/GRP78. В покое держит σ1R неактивным.',x:250,y:40,w:50},
  {id:'ip3r3',l:'IP3R3',d:'Кальциевый канал на ЭР. σ1R стабилизирует → Ca²⁺.',x:540,y:40,w:55},
  {id:'ca',l:'Ca²⁺',d:'Ионы кальция. Триггер киназных каскадов и АТФ.',x:660,y:90,w:50},
  {id:'mito',l:'Мито',d:'Митохондрия. Ca²⁺ → производство АТФ.',x:750,y:40,w:50},
  {id:'atp',l:'АТФ',d:'Энергия для синаптической пластичности и LTP.',x:750,y:130,w:50},
  {id:'camk',l:'CaMKII',d:'Кальций-кальмодулин киназа II/IV.',x:550,y:170,w:60},
  {id:'erk',l:'ERK1/2',d:'MAP-киназа. Передаёт сигнал к CREB.',x:450,y:240,w:60},
  {id:'creb',l:'CREB',d:'Транскрипционный фактор. CREB → BDNF.',x:400,y:330,w:55},
  {id:'bdnf',l:'BDNF',d:'Нейротрофический фактор. Нейрогенез, пластичность, реконсолидация.',x:400,y:420,w:55},
  {id:'ire1',l:'IRE1',d:'σ1R стабилизирует IRE1 → XBP1. Альт. путь к BDNF.',x:250,y:170,w:50},
  {id:'xbp1',l:'XBP1',d:'Транскрипционный фактор. Доп. путь к BDNF.',x:250,y:280,w:55},
  {id:'sk',l:'SK-кан.',d:'SK калиевые каналы. σ1R ингибирует → потенцирование NMDA.',x:660,y:210,w:60},
  {id:'nmda',l:'NMDA-R',d:'NMDA-рецептор. Потенцирование = основа LTP.',x:700,y:300,w:65},
  {id:'glun',l:'GluN2A/2B',d:'σ1R → трафик субъединиц к мембране.',x:600,y:340,w:70},
  {id:'psd',l:'PSD-95',d:'Скаффолд. Организует рецепторы в постсинапсе.',x:650,y:400,w:60},
  {id:'ltp',l:'LTP',d:'Долговременная потенциация. Обучение, память.',x:600,y:470,w:50},
  {id:'recon',l:'Реконсол.',d:'Реконсолидация травматических воспоминаний (EMDR/PE).',x:500,y:500,w:70}
];
var S1E=[
  {f:'s1r',t:'bip',tp:'inh',l:'Диссоциация'},
  {f:'s1r',t:'ip3r3',tp:'stab',l:'Стабилизация'},
  {f:'ip3r3',t:'ca',tp:'act',l:'Ca²⁺ выброс'},
  {f:'ca',t:'mito',tp:'act'},
  {f:'mito',t:'atp',tp:'prod'},
  {f:'ca',t:'camk',tp:'act'},
  {f:'camk',t:'erk',tp:'act'},
  {f:'erk',t:'creb',tp:'act'},
  {f:'creb',t:'bdnf',tp:'prod',l:'Транскрипция'},
  {f:'s1r',t:'ire1',tp:'stab',l:'Стабилизация'},
  {f:'ire1',t:'xbp1',tp:'act'},
  {f:'xbp1',t:'bdnf',tp:'prod',l:'Доп. BDNF'},
  {f:'s1r',t:'sk',tp:'inh',l:'Ингибиция SK'},
  {f:'sk',t:'nmda',tp:'act',l:'NMDA потенц.'},
  {f:'s1r',t:'glun',tp:'act',l:'Трафик'},
  {f:'glun',t:'psd',tp:'act',l:'+PSD-95'},
  {f:'nmda',t:'ltp',tp:'act'},
  {f:'psd',t:'ltp',tp:'act'},
  {f:'bdnf',t:'recon',tp:'act'},
  {f:'ltp',t:'recon',tp:'act'}
];

function s1Bal(){var ag=0,inv=0,ant=0;Object.keys(AD).forEach(function(did){var d=DRUGS[did];if(!d||!d.ki||!d.ki.s1)return;var o=occ(did,'s1');
  if(d.s1t==='ag')ag+=o;else if(d.s1t==='inv')inv+=o;else if(d.s1t==='ant')ant+=o});return{ag:ag,inv:inv,ant:ant,net:ag-inv-ant}}

function buildS1SVG(){var svg=document.getElementById('s1svg');var bal=s1Bal();
  var hasAny=bal.ag>0||bal.inv>0||bal.ant>0;
  var state=!hasAny?'off':bal.net>10?'ag':bal.net<-10?'inv':bal.ant>20?'ant':'mix';
  var nc=state==='ag'?'#22c55e':state==='inv'?'#ef4444':state==='ant'?'#f59e0b':state==='mix'?'#a78bfa':'#475569';
  var ec=state==='ag'?'#16a34a':state==='inv'?'#dc2626':state==='ant'?'#d97706':state==='mix'?'#7c3aed':'#334155';
  var glow=state==='ag'?'rgba(34,197,94,.3)':state==='inv'?'rgba(239,68,68,.3)':state==='mix'?'rgba(167,139,250,.3)':'rgba(71,85,105,.2)';
  var speed=state==='ag'?'2s':state==='inv'?'8s':state==='mix'?'4s':'0s';
  var nmap={};S1N.forEach(function(n){nmap[n.id]=n});
  var h='<defs><filter id="s1glow"><feGaussianBlur stdDeviation="4" result="b"/><feMerge><feMergeNode in="b"/><feMergeNode in="SourceGraphic"/></feMerge></filter></defs>';
  // edges
  S1E.forEach(function(e,i){var fn=nmap[e.f],tn=nmap[e.t];if(!fn||!tn)return;
    var x1=fn.x,y1=fn.y+15,x2=tn.x,y2=tn.y-15;
    var mx=(x1+x2)/2,my=(y1+y2)/2;
    var pid='s1p'+i;
    h+='<path id="'+pid+'" d="M'+x1+','+y1+' Q'+mx+','+(my-15)+' '+x2+','+y2+'" fill="none" stroke="'+ec+'" stroke-width="1.5" opacity="0.5"/>';
    if(state!=='off'){
      for(var p=0;p<3;p++){
        h+='<circle r="3" fill="'+nc+'" opacity="0.8" filter="url(#s1glow)"><animateMotion dur="'+speed+'" begin="'+(p*0.7)+'s" repeatCount="indefinite"><mpath href="#'+pid+'"/></animateMotion></circle>';
      }
    }
    if(e.l){h+='<text x="'+mx+'" y="'+(my-8)+'" fill="'+ec+'" font-size="7" text-anchor="middle" opacity="0.7">'+e.l+'</text>'}
  });
  // nodes
  S1N.forEach(function(n){
    var fill=n.id==='bdnf'?(state==='ag'?'#22c55e':state==='inv'?'#7f1d1d':'#1e293b'):
              n.id==='ltp'?(state==='ag'?'#16a34a':state==='inv'?'#7f1d1d':'#1e293b'):
              n.id==='recon'?(state==='ag'?'#059669':state==='inv'?'#991b1b':'#1e293b'):'#0f172a';
    var stroke=n.id==='s1r'?'#c084fc':nc;
    var w=n.w||55,hw=w/2;
    h+='<g class="s1node" onmouseenter="s1TT(evt,\''+n.d.replace(/'/g,"\\'")+'\')" onmouseleave="s1TH()">';
    h+='<rect x="'+(n.x-hw)+'" y="'+(n.y-14)+'" width="'+w+'" height="28" rx="8" fill="'+fill+'" stroke="'+stroke+'" stroke-width="1.5" filter="url(#s1glow)"/>';
    h+='<text x="'+n.x+'" y="'+(n.y+4)+'" fill="'+(state==='off'?'#64748b':'#e2e8f0')+'" font-size="10" font-weight="700" text-anchor="middle">'+n.l+'</text>';
    h+='</g>';
  });
  // nucleus label
  h+='<text x="400" y="370" fill="#475569" font-size="8" text-anchor="middle" opacity="0.5">—— ЯДРО (транскрипция) ——</text>';
  h+='<text x="400" y="15" fill="#475569" font-size="8" text-anchor="middle" opacity="0.5">—— ЭР мембрана (MAM) ——</text>';
  h+='<text x="700" y="250" fill="#475569" font-size="8" text-anchor="middle" opacity="0.4">Постсинапс</text>';
  svg.innerHTML=h;
  // status
  var st=document.getElementById('s1status');
  var info=document.getElementById('s1info');
  if(state==='ag'){
    st.textContent='σ1-агонизм активен (баланс: +'+bal.net.toFixed(0)+'%)';st.style.color='#22c55e';
    var agDrugs=[];Object.keys(AD).forEach(function(d){var dr=DRUGS[d];if(dr&&dr.s1t==='ag'&&dr.ki&&dr.ki.s1){agDrugs.push(dr.s+' σ1:'+occ(d,'s1').toFixed(0)+'%')}});
    info.textContent='Активные σ1-агонисты: '+agDrugs.join(', ')+' → каскад BiP→Ca²⁺→BDNF→LTP активен';
    info.classList.add('show');
  }else if(state==='inv'){
    st.textContent='σ1-инверсный агонизм (баланс: '+bal.net.toFixed(0)+'%)';st.style.color='#ef4444';
    info.innerHTML='⚠️ σ1 инверсный агонизм подавляет LTP и BDNF-транскрипцию.<br>Это может снижать эффективность травма-терапии (EMDR, PE).';
    info.classList.add('show');
  }else if(state==='ant'){
    st.textContent='σ1-антагонизм (блокада каскада)';st.style.color='#f59e0b';
    info.textContent='σ1-антагонист блокирует весь каскад нейропластичности.';info.classList.add('show');
  }else if(state==='mix'){
    st.textContent='σ1-конкуренция агонист vs инверсный — исход зависит от индивидуальной фармакокинетики';st.style.color='#a78bfa';
    var parts=[];Object.keys(AD).forEach(function(d){var dr=DRUGS[d];if(dr&&dr.s1t&&dr.ki&&dr.ki.s1){parts.push(dr.s+' ('+dr.s1t+') σ1:'+occ(d,'s1').toFixed(0)+'%')}});
    info.textContent='Конкуренция: '+parts.join(' vs ')+' → каскад частично активен';info.classList.add('show');
  }else{
    st.textContent='Нет активных σ1-лигандов';st.style.color='#94a3b8';info.classList.remove('show');
  }
}

// === ZONE POPUP + RIGHT PANEL TOGGLE ===
function showZonePopup(zoneId,sp){
  var zone=RG[zoneId];var popup=document.getElementById('zone-popup');
  var x=sp.x+20,y=sp.y-30;
  if(x+260>innerWidth-20)x=sp.x-280;
  if(y+200>innerHeight-80)y=innerHeight-280;
  if(x<0)x=10;if(y<0)y=10;
  popup.style.left=x+'px';popup.style.top=y+'px';
  document.getElementById('zp-title').textContent=zone.f;
  document.getElementById('zp-sub').textContent=zone.fn;
  document.getElementById('zp-dot').style.background=zone.c;
  document.getElementById('zp-dot').style.boxShadow='0 0 8px '+zone.c;
  var body='';
  Object.keys(AD).forEach(function(did){var d=DRUGS[did];if(!d||!d.z||!d.z[zoneId])return;
    var zd=d.z[zoneId];var isBad=zd.bad;
    var arrow=isBad?'\u2193':'\u2191';var cls=isBad?'down':'up';
    body+='<div class="popup-effect"><span class="popup-effect-arrow '+cls+'">'+arrow+'</span>';
    body+='<span class="popup-effect-name" style="color:'+d.c+'">'+d.s+'</span>';
    body+='<span class="popup-effect-detail">'+zd.fx[0]+'</span></div>'});
  if(!body)body='<div style="color:var(--text-muted);font-style:italic;font-size:11px">Нет активных препаратов</div>';
  document.getElementById('zp-body').innerHTML=body;
  popup.dataset.zoneId=zoneId;
  popup.classList.remove('hidden')
}
function closeZonePopup(){document.getElementById('zone-popup').classList.add('hidden')}
window.closeZonePopup=closeZonePopup;
window.openRightPanelForZone=function(){
  var zid=document.getElementById('zone-popup').dataset.zoneId;
  closeZonePopup();SR=zid;uAll();
  var rp=document.getElementById('rp');if(!rp.classList.contains('open')){rp.classList.add('open');rsz();setTimeout(rsz,350)}
};
window.toggleRightPanel=function(){document.getElementById('rp').classList.toggle('open');rsz();setTimeout(rsz,350)};
function updatePanelBadge(){var b=document.getElementById('panel-badge');if(!b)return;
  var el=document.getElementById('cfb');var hasIssues=el&&el.innerHTML.length>10;
  b.classList.toggle('hidden',!hasIssues)}

window.showS1=function(){buildS1SVG();document.getElementById('s1overlay').classList.add('show')};
window.s1TT=function(evt,txt){var tt=document.getElementById('s1tooltip');tt.style.display='block';tt.style.left=(evt.clientX+12)+'px';tt.style.top=(evt.clientY-10)+'px';tt.textContent=txt};
window.s1TH=function(){document.getElementById('s1tooltip').style.display='none'};
document.addEventListener('keydown',function(e){if(e.key==='Escape'){document.getElementById('s1overlay').classList.remove('show');closeZonePopup();var rp=document.getElementById('rp');if(rp.classList.contains('open'))rp.classList.remove('open')}});

(function(){
  var pc=document.createElement('canvas');
  pc.style.cssText='position:absolute;inset:0;z-index:1;pointer-events:none';
  document.getElementById('cv').insertBefore(pc,document.getElementById('cv').firstChild);
  var ctx=pc.getContext('2d');
  var dots=[];for(var i=0;i<80;i++){dots.push({x:Math.random(),y:Math.random(),r:Math.random()*1.5+0.5,o:Math.random()*0.3+0.05,vx:(Math.random()-0.5)*0.0002,vy:(Math.random()-0.5)*0.0002})}
  function rsz2(){pc.width=pc.parentElement.clientWidth;pc.height=pc.parentElement.clientHeight}
  window.addEventListener('resize',rsz2);rsz2();
  (function draw(){ctx.clearRect(0,0,pc.width,pc.height);dots.forEach(function(d){d.x+=d.vx;d.y+=d.vy;if(d.x<0)d.x=1;if(d.x>1)d.x=0;if(d.y<0)d.y=1;if(d.y>1)d.y=0;ctx.beginPath();ctx.arc(d.x*pc.width,d.y*pc.height,d.r,0,Math.PI*2);ctx.fillStyle='rgba(200,210,230,'+d.o+')';ctx.fill()});requestAnimationFrame(draw)})();
})();

var clk = new THREE.Clock();
(function anim(){requestAnimationFrame(anim);var t=clk.getElapsedTime();ctrl.update();
  Object.values(MK).forEach(function(m){if(m.material.emissiveIntensity>0.3)m.material.emissiveIntensity+=Math.sin(t*3)*0.015});
  if(DSEL){var df=DEFICITS.find(function(x){return x.id===DSEL});if(df&&df.status==='critical'){df.zones.forEach(function(z){if(MK[z]){MK[z].material.opacity=0.6+0.4*Math.sin(t*4);MK[z].scale.setScalar(1.4+0.2*Math.sin(t*3))}})}}
  mg.children.forEach(function(c){if(c.userData.isR){c.lookAt(cam.position);c.material.opacity=0.2+Math.sin(t*2)*0.08}});
  TL.forEach(function(l){if(l.material.opacity>0)l.material.opacity=0.2+Math.sin(t*2)*0.15});
  if(window._brainParticles){window._brainParticles.rotation.y+=0.0003;window._brainParticles.material.opacity=0.3+Math.sin(Date.now()*0.001)*0.1}
  composer.render();
})();
</script>
</body>
</html>
